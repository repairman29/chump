# Antigravity workspace clone (nested duplicate of repo)
# Anchored to repo root so legitimate subdir names like registry-submission/chump/ aren't matched
/chump/


# Dead submodule directories (Antigravity cleanup deletes these from repo,
# but local filesystems may still have them)
repos/repairman29_beast-mode
repos/repairman29_chump-chassis

acp_sessions/

# Agent path-lease files (src/agent_lease.rs, docs/AGENT_COORDINATION.md).
# Lock files are per-session, RFC3339-stamped, and expire locally — they
# must never land in git. One leaked lock file on main pollutes every
# agent's working tree on pull and never expires (the "live lease" check
# in the pre-commit hook would then block legitimate edits from whichever
# session doesn't match the committed session_id).
.chump-locks/

# JetBrains IDEs (IntelliJ IDEA, RustRover, etc.)
.idea/
*.iml
.chump/overnight/
# INFRA-094: per-machine marker written by chump gap dump/ship; the
# pre-commit raw-YAML-edit advisory reads this to confirm a docs/gaps.yaml
# diff was authored by the chump CLI rather than a hand-edit.
.chump/.last-yaml-op

# INFRA-202: per-machine sccache config (created by scripts/setup/install-sccache.sh)
.cargo/config.toml

# Runtime/operational state (local only — not committed)
.chump/activation/
.chump/alerts.log
.chump/health.jsonl

# INFRA-188 + INFRA-208: docs/gaps.yaml was deleted in the per-file cutover
# but stale chump binaries (or any code path that calls dump_yaml() against
# the legacy path) keep recreating it locally as a side-effect. Ignore so
# that those accidental re-creations don't pollute `git status` or end up
# in commits. The canonical layout is docs/gaps/<ID>.yaml.
docs/gaps.yaml

# Private swarm-autonomy work — must NEVER be committed to the public repo.
