# Claude Code local worktrees and runtime files (never commit)
# Use .claude/* (not .claude/) so we can re-include settings.json below
.claude/*
!.claude/settings.json
# INFRA-1917: productized curator roles + skills live in .claude/ and are
# canonical (committed); other .claude/ runtime (projects/, shell-snapshots/,
# statsig/, settings.local.json) stays local-only via the broad .claude/* rule.
!.claude/agents/
!.claude/agents/*.md
!.claude/skills/
!.claude/skills/*/
!.claude/skills/*/SKILL.md
# INFRA-188: chump-native worktree directory (canonical post-INFRA-186)
.chump/worktrees/

# META-016 (2026-05-02): ephemeral session notes / handoff scratchpads.
# A background process — `git stash push -u` named claude-other-stash /
# claude-watch-stash — captures untracked-but-not-ignored content under
# .chump/notes/ and never pops it back. Recovery via `git stash list`
# + `git ls-tree stash@{N}^3 -- .chump/notes/` works, but gitignoring
# the dir defangs the mechanism: stash -u + clean -fd both skip ignored
# files (verified empirically). The durable canonical location for
# session-handoff notes is
# ~/.claude/projects/-Users-jeffadkins-Projects-Chump/notes/ (outside
# any git tree, immune to all git ops).
.chump/notes/

# Agent path-lease files (runtime only; never commit)
.chump-locks/

# SQLite gap store — binary DB is not committed; only the compressed .lz4 is tracked
.chump/state.db
.chump/state.db-shm
.chump/state.db-wal
.chump/state.db.bak
.chump/state.sql

# Auditor (INFRA-087) runtime state — strikes index + raw findings dumps
.chump/auditor-strikes.json
.chump/auditor-findings-*.jsonl
.chump/pr-health-findings.jsonl

# Local SQLite scratch DBs at repo root — never commit (untracked in INFRA-84)
/chump.db
/chump_memory.db

# Post-ship sentinel (INFRA-BOT-MERGE-LOCK) — worktree-local, never commit
.bot-merge-shipped

