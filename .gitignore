# Agent path-lease files (runtime only; never commit)
.chump-locks/

# SQLite gap store — binary DB is not committed; only the .sql dump is tracked
.chump/state.db
.chump/state.db-shm
.chump/state.db-wal

# Auditor (INFRA-087) runtime state — strikes index + raw findings dumps
.chump/auditor-strikes.json
.chump/auditor-findings-*.jsonl
.chump/pr-health-findings.jsonl

# Local SQLite scratch DBs at repo root — never commit (untracked in INFRA-84)
/chump.db
/chump_memory.db

# Post-ship sentinel (INFRA-BOT-MERGE-LOCK) — worktree-local, never commit
.bot-merge-shipped

# Cursor IDE: ignore local state; team rules live in .cursor/rules/ (tracked)
.cursor/*
