# Copy to .env and set your bot token from Discord Developer Portal → Bot → Reset Token
DISCORD_TOKEN=your-bot-token-here

# Tavily web search (research / self-improvement). Required for heartbeat-learn overnight runs. Get a key at tavily.com; ~1000 credits/month on free tier.
# TAVILY_API_KEY=your-tavily-api-key

# Optional: Discord user ID for DMs. When the Discord bot runs: "Chump is online" on connect. When Chump uses the notify tool (Discord or heartbeat/CLI): DMs go here. Enable Developer Mode in Discord, right-click your profile → Copy User ID. For heartbeat DMs, DISCORD_TOKEN must also be set.
# CHUMP_READY_DM_USER_ID=123456789012345678

# Optional: focus Chump on projects/repos (see docs/USER_STORIES.md)
# CHUMP_PROJECT_MODE=1

# Optional: context caps. Memory/ego/tasks/context_assembly do the heavy lifting; these just bound growth.
# CHUMP_MAX_CONTEXT_MESSAGES=20   # max conversation turns sent to model (default 20)
# CHUMP_OLLAMA_NUM_CTX=4096      # Ollama context window (default 4096; lower saves RAM, may hurt quality)

# Optional: start Ollama (or MLX servers) on first Discord message instead of keeping them always on (see docs/CHUMP_SERVICE.md)
# CHUMP_WARM_SERVERS=1
# CHUMP_HOME is set by run scripts to repo root; override here only if needed (e.g. ~/Projects/Chump).
# CHUMP_HOME=/path/to/Chump

# Optional: brain wiki for memory_brain tool (default chump-brain/). Create dir and add self.md (see docs/CHUMP_BRAIN.md).
# CHUMP_BRAIN_PATH=chump-brain

# Optional: keep-chump-online and Farmer Brown. When 1, keep-chump-online.sh starts Ollama/Discord/embed if down.
# CHUMP_KEEPALIVE_DISCORD=1   # start Chump Discord if not running (requires DISCORD_TOKEN)
# CHUMP_KEEPALIVE_EMBED=1     # start embed server on CHUMP_EMBED_PORT (18765) if not up

# Optional: enable delegate tool (summarize/extract). Worker uses same Ollama when CHUMP_WORKER_API_BASE is unset.
# CHUMP_DELEGATE=1
# For a separate worker instance: CHUMP_WORKER_API_BASE=http://localhost:11435/v1

# Optional: repo awareness + read/write tools + full exec (see docs/TROUBLESHOOTING.md)
# CHUMP_REPO or CHUMP_HOME: repo root for run_cli cwd, read_file/list_dir/write_file (e.g. ~/Projects/Chump)
# CHUMP_REPO=/path/to/Chump
# CHUMP_EXECUTIVE_MODE=1            # no allowlist/blocklist; 300s timeout, 50k output cap; audit in chump.log
# CHUMP_EXECUTIVE_TIMEOUT_SECS=300
# CHUMP_EXECUTIVE_MAX_OUTPUT_CHARS=50000

# Optional: ADB tool (Android device over Wi-Fi, e.g. Pixel on Tailscale). See docs/ROADMAP_ADB.md.
# Pair once: adb pair <ip>:<pairing_port> and enter code; then set CHUMP_ADB_DEVICE to the connect address (ip:port from wireless debugging screen).
# CHUMP_ADB_ENABLED=1
# CHUMP_ADB_DEVICE=100.121.127.45:34085
# CHUMP_ADB_TIMEOUT=30
# CHUMP_ADB_MAX_OUTPUT=4000
# CHUMP_ADB_ALLOWLIST=input,screencap,shell,status   # optional: restrict to these actions

# Optional: GitHub read (Phase 3) and git commit/push (Phase 4). See docs/ROADMAP_DOGFOOD_SELF_IMPROVE.md
# GITHUB_TOKEN=ghp_...   # or CHUMP_GITHUB_TOKEN; PAT with repo read (and write for push)
# CHUMP_GITHUB_REPOS=owner/chump,owner/other   # allowlist; github_repo_read, github_repo_list, github_clone_or_pull, git_commit, git_push only for these
# CHUMP_AUTO_PUSH=0   # when 1, Chump may push after commit without a second "push" confirmation (chump/* branches only). With this and CHUMP_GITHUB_REPOS set, the bot can push to Chump and run scripts/self-reboot.sh after bot-affecting changes to restart with new capabilities.
# CHUMP_SELF_REBOOT_DELAY=10   # seconds to wait before killing the Discord bot in self-reboot.sh (default 10). Lets the bot send "reboot scheduled" before exit.
# CHUMP_AUTO_PUBLISH=0   # when 1, Chump may push to main and create releases (bump Cargo.toml, CHANGELOG, tag vX.Y.Z, push --tags). One release per logical batch. Used by heartbeat-self-improve.
# CHUMP_CURSOR_CLI=0   # when 1, Chump may invoke Cursor CLI (agent -p "..." --force) to fix issues when you're online. Requires Cursor CLI in PATH; add agent to CHUMP_CLI_ALLOWLIST if set. See docs/CURSOR_CLI_INTEGRATION.md.
