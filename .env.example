# =============================================================================
# External / first-time safety (read before copying)
# =============================================================================
# Chump is self-hosted: you bring API keys and models. For a minimal first run
# (Ollama + web or CLI only), see docs/EXTERNAL_GOLDEN_PATH.md — you can comment
# out DISCORD_TOKEN until you use Discord (a non-empty placeholder makes the
# config summary list "discord" even though the token is invalid).
#
# High-risk or irreversible when mis-set (review before enabling in production):
#   CHUMP_EXECUTIVE_MODE — very permissive run_cli; no allowlist/blocklist.
#   CHUMP_AUTO_PUSH / CHUMP_AUTO_PUBLISH — bot may git push without extra confirm.
#   CHUMP_AUTO_APPROVE_* / CHUMP_RPC_* — autonomy and headless paths; audit logs only.
# Some provider cascade slots TRAIN on free-tier data — see docs/PROVIDER_CASCADE.md
# and CHUMP_PROVIDER_*_PRIVACY=trains markers in the cascade block below.
# =============================================================================

# --- Cowork / M4 stability (recommended defaults; see docs/CLAUDE_COWORK_UPGRADE_PLAN.md Phase 1) ---
# Observability (Cowork-tier engine: agent loop, task executor, speculative batches; axonerai quieter).
RUST_LOG=warn,chump=debug,chump::agent_loop=debug,chump::task_executor=debug,chump::speculative_execution=debug,axonerai=info
# Tauri desktop (`chump --desktop`): base URL for the Chump **web** sidecar (default http://127.0.0.1:3000). Set if web listens on another port.
# CHUMP_DESKTOP_API_BASE=http://127.0.0.1:3001
# Cap vLLM concurrent sequences and Discord/agent turns to reduce Metal OOM risk on unified memory.
# VLLM_MAX_NUM_SEQS=1
# CHUMP_MAX_CONCURRENT_TURNS=1
# Delegate stays off unless you enable cluster mode and a healthy mesh (see CHUMP_CLUSTER_MODE block below).
# CHUMP_DELEGATE=0

# Copy to .env and set your bot token from Discord Developer Portal → Bot → Reset Token
# Inference: see docs/INFERENCE_PROFILES.md — primary Mac profile is vLLM-MLX :8000 (14B); optional lite MLX :8001 (7B); Ollama :11434 is the dev/simple profile.
# Lite MLX only (smaller model, port 8001):
# OPENAI_API_BASE=http://127.0.0.1:8001/v1
# OPENAI_API_KEY=not-needed
# OPENAI_MODEL=mlx-community/Qwen2.5-7B-Instruct-4bit
# Start: ./scripts/serve-vllm-mlx-8001.sh  or  ./scripts/restart-vllm-8001-if-down.sh
DISCORD_TOKEN=your-bot-token-here

# Tavily web search (research / self-improvement). Required for heartbeat-learn overnight runs. Get a key at tavily.com; ~1000 credits/month on free tier.
# TAVILY_API_KEY=your-tavily-api-key

# Optional: Discord user ID for DMs. When the Discord bot runs: "Chump is online" on connect. When Chump uses the notify tool (Discord or heartbeat/CLI): DMs go here. Hourly update script and "reach out when stuck" also use this. Enable Developer Mode in Discord, right-click your profile → Copy User ID. For heartbeat/hourly DMs, DISCORD_TOKEN must also be set.
# CHUMP_READY_DM_USER_ID=123456789012345678

# Optional: during heartbeat (CHUMP_HEARTBEAT_TYPE set), restrict the notify tool to interrupt-worthy messages only (see docs/COS_DECISION_LOG.md).
# CHUMP_INTERRUPT_NOTIFY_POLICY=restrict
# Optional: extra comma-separated case-insensitive substrings that always allow notify during restrict mode.
# CHUMP_NOTIFY_INTERRUPT_EXTRA=my-oncall-code

# Optional: CI failure digest dedupe store (default logs/ci-failure-dedupe.tsv; gitignored). See scripts/ci-failure-digest.sh
# CI_FAILURE_DEDUPE=0
# CI_FAILURE_DEDUPE_FILE=/path/to/ci-failure-dedupe.tsv

# Optional: repo-health-sweep safe autofix (chmod +x scripts/*.sh only). See scripts/repo-health-sweep.sh
# REPO_HEALTH_AUTOFIX=1

# Optional: max concurrent Discord turns (1 = one at a time; user messages when busy are queued and answered at next free moment). 0 = no limit. Recommended 1 for autopilot so heartbeats and your messages don't contend.
# CHUMP_MAX_CONCURRENT_TURNS=1

# Optional: focus Chump on projects/repos (see docs/USER_STORIES.md)
# CHUMP_PROJECT_MODE=1

# Optional: start Ollama on first Discord message instead of keeping it always on (see docs/CHUMP_SERVICE.md)
# CHUMP_WARM_SERVERS=1
# CHUMP_HOME is set by run scripts to repo root; override here only if needed (e.g. ~/Projects/Chump).
# CHUMP_HOME=/path/to/Chump

# Optional: brain wiki for memory_brain tool (default chump-brain/). Create dir and add self.md (see docs/CHUMP_BRAIN.md).
# CHUMP_BRAIN_PATH=chump-brain

# Optional: keep-chump-online and Farmer Brown. When 1, keep-chump-online.sh starts Ollama/Discord/embed if down.
# CHUMP_KEEPALIVE_DISCORD=1   # start Chump Discord if not running (requires DISCORD_TOKEN)
# CHUMP_KEEPALIVE_EMBED=1     # start embed server on CHUMP_EMBED_PORT (18765) if not up

# Swarm / cluster toggle (see docs/ROADMAP_CLAUDE_UPGRADE.md Phase 8). Default off = local-primary only: ignores CHUMP_DELEGATE and CHUMP_WORKER_API_BASE for routing.
# When 1, probes inference mesh (see scripts/check-inference-mesh.sh); on failure falls back to local-primary for the process.
# CHUMP_CLUSTER_MODE=1
# Optional: only probe Mac URL (skip iPhone Tailscale :8889) when testing swarm flag without an iPhone node.
# CHUMP_CLUSTER_MESH_SKIP_IPHONE=1
# Override mesh probe URLs (defaults: Mac http://127.0.0.1:8000/v1/models, iPhone http://10.1.10.175:8889/v1/models).
# INFERENCE_MESH_MAC_URL=http://127.0.0.1:8000/v1/models
# INFERENCE_MESH_IPHONE_URL=http://10.1.10.175:8889/v1/models

# Optional: enable delegate tool (summarize/extract). Effective only when CHUMP_CLUSTER_MODE=1 and mesh probe succeeded; otherwise ignored.
# CHUMP_DELEGATE=1
# For a separate worker instance (cluster mode + mesh up): CHUMP_WORKER_API_BASE=http://localhost:11435/v1

# Agent intelligence: thinking mode, context window, brain autoload
# CHUMP_THINKING=1                    # prepend /think (Qwen3 thinking mode); strip_thinking() removes blocks before Discord output
# CHUMP_CONTEXT_SUMMARY_THRESHOLD=6000  # summarize/trim history when approx tokens exceed this (e.g. 6000 = ~80% of 8k context)
# CHUMP_BRAIN_AUTOLOAD=self.md        # comma-separated brain-relative paths auto-injected into context (e.g. self.md,wiki/focus.md)

# Autonomy + RPC (see docs/AUTONOMY_ROADMAP.md, docs/OPERATIONS.md)
# CHUMP_AUTONOMY_ASSIGNEE=chump
# CHUMP_AUTONOMY_OWNER=mac-studio-1
# CHUMP_TASK_LEASE_TTL_SECS=900
# CHUMP_RPC_JSONL_LOG=logs/rpc-events.jsonl

# Fleet / Mabel on Pixel (see docs/OPERATIONS.md, docs/ANDROID_COMPANION.md, scripts/heartbeat-mabel.sh)
# CHUMP_MABEL=1
# MAC_TAILSCALE_IP=100.x.y.z
# MAC_CHUMP_HOME=~/Projects/Chump
# MABEL_HEAVY_MODEL_BASE=http://100.x.y.z:8000/v1
# MABEL_FARMER_FIX_LOCAL=1

# Consciousness framework tunables (see docs/METRICS.md, docs/CHUMP_TO_COMPLEX.md)
# CHUMP_CONSCIOUSNESS_ENABLED=1      # set to 0 to disable all consciousness module injections (A/B testing)
# Consciousness exercise (scripts/consciousness-exercise.sh): Ollama uses qwen2.5:7b by default (ignores OPENAI_MODEL from .env for latency).
# CHUMP_EXERCISE_MODEL=qwen2.5:7b
# CHUMP_EXERCISE_TIMEOUT=240
# CHUMP_SURPRISE_EMA_ALPHA=0.3       # EMA smoothing for surprisal (lower = smoother)
# CHUMP_BLACKBOARD_MAX_AGE_SECS=600  # evict blackboard entries older than this
# CHUMP_BLACKBOARD_BROADCAST_THRESHOLD=0.4  # min salience to broadcast (0.0–1.0)
# CHUMP_GRAPH_MAX_HOPS=2             # max hops for associative memory graph recall
# CHUMP_SESSION_ENERGY_TOKENS=0      # per-session token energy budget (0 = unlimited)
# CHUMP_SESSION_ENERGY_TOOLS=0       # per-session tool call energy budget (0 = unlimited)

# Optional: repo awareness + read/write tools + full exec (see docs/TROUBLESHOOTING.md)
# CHUMP_REPO or CHUMP_HOME: repo root for run_cli cwd, read_file/list_dir/write_file (e.g. ~/Projects/Chump)
# CHUMP_REPO=/path/to/Chump
# CHUMP_EXECUTIVE_MODE=1            # no allowlist/blocklist; 300s timeout, 50k output cap; audit in chump.log
# CHUMP_EXECUTIVE_TIMEOUT_SECS=300
# CHUMP_EXECUTIVE_MAX_OUTPUT_CHARS=50000

# Optional: tools requiring human or peer approval. CHUMP_TOOLS_ASK=run_cli,write_file,git_push (comma-separated); Discord/web show Allow/Deny. CHUMP_PEER_APPROVE_TOOLS=git_push,merge_pr: when Chump requests approval for these, he also writes brain/a2a/pending_approval.json so Mabel can run Verify, then POST /api/approve (two-key safety). See OPERATIONS.md.
# CHUMP_TOOLS_ASK=run_cli,write_file,git_push
# CHUMP_PEER_APPROVE_TOOLS=git_push,merge_pr
# Optional: autonomy / headless RPC — skip approval UI when explicitly safe (still audit to chump.log as tool_approval_audit).
# CHUMP_AUTO_APPROVE_LOW_RISK=1   # if run_cli is in CHUMP_TOOLS_ASK, auto-allow when heuristic_risk is Low (e.g. cargo test)
# CHUMP_AUTO_APPROVE_TOOLS=read_file,calc   # auto-allow these tools when they are also listed in CHUMP_TOOLS_ASK

# Optional: ADB tool (Android device over Wi-Fi, e.g. Pixel on Tailscale). See docs/ROADMAP_ADB.md.
# Pair once: adb pair <ip>:<pairing_port> and enter code; then set CHUMP_ADB_DEVICE to the connect address (ip:port from wireless debugging screen).
# CHUMP_ADB_ENABLED=1
# CHUMP_ADB_DEVICE=100.121.127.45:34085
# CHUMP_ADB_TIMEOUT=30
# CHUMP_ADB_MAX_OUTPUT=4000
# CHUMP_ADB_ALLOWLIST=input,screencap,shell,status   # optional: restrict to these actions

# Optional: ephemeral git worktree sandbox (one command, then teardown). See src/sandbox_tool.rs.
# CHUMP_SANDBOX_ENABLED=1
# CHUMP_SANDBOX_TIMEOUT_SECS=120

# Optional: screenshot + vision model (OpenAI-style /v1/chat/completions with image). Mac: screencapture; Android: ADB when CHUMP_ADB_* set.
# CHUMP_SCREEN_VISION_ENABLED=1
# CHUMP_VISION_MODEL=gpt-4o-mini
# CHUMP_VISION_API_BASE=https://api.openai.com/v1   # optional; defaults to OPENAI_API_BASE
# CHUMP_VISION_TIMEOUT_SECS=120

# Optional: blackboard salience — set to 0 to disable neuromodulation factor scaling (legacy scoring).
# CHUMP_NEUROMOD_SALIENCE_WEIGHTS=0
# Nudge precision regimes from recent task outcomes (done/blocked via task_db); rolling window.
# CHUMP_ADAPTIVE_REGIME=1

# Multi-tool batch: fork/evaluate/rollback in agent_loop (≥3 tools). Set to 0 to disable.
# CHUMP_SPECULATIVE_BATCH=0
# Max allowed increase in surprisal EMA during that batch (since fork); default 0.25.
# CHUMP_SPECULATIVE_SURPRISE_DELTA_MAX=0.25

# When 1, skip pre-execute validation of required tool JSON fields (read_file path, run_cli command, etc.).
# CHUMP_SKIP_TOOL_INPUT_VALIDATE=1

# Optional: GitHub read (Phase 3) and git commit/push (Phase 4). See docs/ROADMAP_DOGFOOD_SELF_IMPROVE.md
# GITHUB_TOKEN=ghp_...   # PAT with repo read (and write for push); used by Chump and Mabel for git push and GitHub tools
# CHUMP_GITHUB_REPOS=owner/chump,owner/other   # allowlist; github_repo_read, github_repo_list, github_clone_or_pull, git_commit, git_push only for these
# CHUMP_AUTO_PUSH=0   # when 1, Chump may push after commit without a second "push" confirmation (chump/* branches only). With this and CHUMP_GITHUB_REPOS set, the bot can push to Chump and run scripts/self-reboot.sh after bot-affecting changes to restart with new capabilities.
# CHUMP_SELF_REBOOT_DELAY=10   # seconds to wait before killing the Discord bot in self-reboot.sh (default 10). Lets the bot send "reboot scheduled" before exit.
# CHUMP_AUTO_PUBLISH=0   # when 1, Chump may push to main and create releases (bump Cargo.toml, CHANGELOG, tag vX.Y.Z, push --tags). One release per logical batch. Used by heartbeat-self-improve.
# CHUMP_CURSOR_CLI=0   # when 1, Chump may invoke Cursor CLI (agent -p "..." --force) to fix issues when you're online. Requires Cursor CLI in PATH; add agent to CHUMP_CLI_ALLOWLIST if set. See docs/CURSOR_CLI_INTEGRATION.md.
# HEARTBEAT_INTERVAL=8m   # self-improve: time between rounds (default 8m). cursor-improve loop default 5m. Use 5m/3m to top out; back off if rounds show exit non-zero.
# Switchable testing: use scripts/env-default.sh and scripts/env-max_m4.sh (or run-tests-with-config.sh <default|max_m4> <script>) to run battle-qa, run-autonomy-tests, etc. against default (Ollama) or max M4 (vLLM-MLX 8000). CHUMP_TEST_CONFIG is set by those scripts.

# --- M4-max (14B on 8000 only, in-process embeddings). Full standard: docs/INFERENCE_PROFILES.md + docs/STEADY_RUN.md. ---
# HF_TOKEN=hf_...   # Hugging Face write token; speeds first-time model downloads (optional)
# OPENAI_API_BASE=http://localhost:8000/v1
# OPENAI_MODEL=mlx-community/Qwen2.5-14B-Instruct-4bit
# CHUMP_MAX_CONCURRENT_TURNS=1   # recommended so Discord and heartbeats don't overload 8000
# CHUMP_MODEL_REQUEST_TIMEOUT_SECS=300   # optional; default 300 for slow 14B
# CHUMP_MODEL_PREFLIGHT_TIMEOUT_SECS=10  # optional; Discord preflight GET /v1/models for local URLs (default 10; was 2s and too tight for vLLM-MLX)
# CHUMP_WARM_SERVERS=1
# Keep CHUMP_DELEGATE unset/0 here unless CHUMP_CLUSTER_MODE=1 and mesh probe succeeds.
# CHUMP_KEEPALIVE_DISCORD=1
# Do NOT set: CHUMP_WORKER_API_BASE, CHUMP_EMBED_URL, WARM_PORT_2 (omit or leave unset).
# Oven-tender will restart vLLM-MLX on 8000 if it crashes. keep-chump-online skips Ollama/embed when OPENAI_API_BASE points to 8000.
# GPU squeeze (see docs/GPU_TUNING.md): after shed-load + stable runs, try higher throughput; if OOM, lower or use 7B.
# VLLM_MAX_NUM_SEQS=1
# VLLM_MAX_TOKENS=16384
# VLLM_CACHE_PERCENT=0.18
# If Metal OOM: VLLM_MAX_TOKENS=4096 VLLM_CACHE_PERCENT=0.12 or MLX_DEVICE=cpu

# --- Provider cascade (optional). See docs/PROVIDER_CASCADE.md. ---
# Stacks free cloud providers for ~71,936 RPD of 70B-class inference. Heartbeat at 5m = 192 RPD = 0.27% of budget.
# Priority routing: Groq (fastest) → Cerebras (huge budget) → Mistral (big TPM) → OpenRouter → Gemini → GitHub → NVIDIA → SambaNova → local fallback.
# All wired providers are used by need: priority, rate limits, privacy, and (optional) CHUMP_PREFER_LARGE_CONTEXT=1 with CONTEXT_K per slot.
# Privacy note: Mistral (slot 3) and Gemini (slot 5) train on free tier — avoid for proprietary code.
# CHUMP_CASCADE_ENABLED=1
# CHUMP_CASCADE_STRATEGY=priority
# CHUMP_CASCADE_RPM_HEADROOM=80
#
# Slot 1: Groq — fastest inference, 70B quality, 1k RPD. Get key: https://console.groq.com
# CHUMP_PROVIDER_1_ENABLED=1
# CHUMP_PROVIDER_1_NAME=groq
# CHUMP_PROVIDER_1_BASE=https://api.groq.com/openai/v1
# CHUMP_PROVIDER_1_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
# CHUMP_PROVIDER_1_MODEL=llama-3.3-70b-versatile
# CHUMP_PROVIDER_1_RPM=24
# CHUMP_PROVIDER_1_RPD=800
# CHUMP_PROVIDER_1_CONTEXT_K=128
# CHUMP_PROVIDER_1_TIER=cloud
# CHUMP_PROVIDER_1_PRIORITY=10
#
# Slot 2: Cerebras — Limits (Personal): 30 RPM, 14,400 RPD. Get key: https://cloud.cerebras.ai
# CHUMP_PROVIDER_2_ENABLED=1
# CHUMP_PROVIDER_2_NAME=cerebras
# CHUMP_PROVIDER_2_BASE=https://api.cerebras.ai/v1
# CHUMP_PROVIDER_2_KEY=csk-xxxxxxxxxxxxxxxxxxxx
# CHUMP_PROVIDER_2_MODEL=llama-3.3-70b
# CHUMP_PROVIDER_2_RPM=30
# CHUMP_PROVIDER_2_RPD=14400
# CHUMP_PROVIDER_2_CONTEXT_K=128
# CHUMP_PROVIDER_2_TIER=cloud
# CHUMP_PROVIDER_2_PRIORITY=15
#
# Slot 3: Mistral — huge TPM (500k). TRAINS ON FREE DATA — skip for code/private. Get key: https://console.mistral.ai/api-keys
# CHUMP_PROVIDER_3_ENABLED=1
# CHUMP_PROVIDER_3_NAME=mistral
# CHUMP_PROVIDER_3_BASE=https://api.mistral.ai/v1
# CHUMP_PROVIDER_3_KEY=xxxxxxxxxxxxxxxxxxxx
# CHUMP_PROVIDER_3_MODEL=mistral-large-latest
# CHUMP_PROVIDER_3_RPM=50
# CHUMP_PROVIDER_3_RPD=50000
# CHUMP_PROVIDER_3_CONTEXT_K=128
# CHUMP_PROVIDER_3_PRIVACY=trains
# CHUMP_PROVIDER_3_TIER=cloud
# CHUMP_PROVIDER_3_PRIORITY=20
#
# Slot 4: OpenRouter — aggregator fallback, many free models. Get key: https://openrouter.ai/keys
# (Optional: $10 lifetime topup upgrades RPD from 200 → 1,000 — highest ROI single spend)
# CHUMP_PROVIDER_4_ENABLED=1
# CHUMP_PROVIDER_4_NAME=openrouter
# CHUMP_PROVIDER_4_BASE=https://openrouter.ai/api/v1
# CHUMP_PROVIDER_4_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx
# CHUMP_PROVIDER_4_MODEL=meta-llama/llama-3.3-70b-instruct:free
# CHUMP_PROVIDER_4_RPM=16
# CHUMP_PROVIDER_4_RPD=800
# CHUMP_PROVIDER_4_CONTEXT_K=128
# CHUMP_PROVIDER_4_TIER=cloud
# CHUMP_PROVIDER_4_PRIORITY=25
#
# Slot 5: Google Gemini — 1M context for big jobs. TRAINS ON FREE DATA. Get key: https://aistudio.google.com/apikey
# CHUMP_PROVIDER_5_ENABLED=1
# CHUMP_PROVIDER_5_NAME=gemini
# CHUMP_PROVIDER_5_BASE=https://generativelanguage.googleapis.com/v1beta/openai
# CHUMP_PROVIDER_5_KEY=AIzaSyxxxxxxxxxxxxxxxxxx
# CHUMP_PROVIDER_5_MODEL=gemini-2.5-flash
# CHUMP_PROVIDER_5_RPM=4
# CHUMP_PROVIDER_5_RPD=16
# CHUMP_PROVIDER_5_CONTEXT_K=1000
# CHUMP_PROVIDER_5_PRIVACY=trains
# CHUMP_PROVIDER_5_TIER=cloud
# CHUMP_PROVIDER_5_PRIORITY=30
#
# Slot 6: GitHub Models — free 70B via GitHub PAT. Get key: https://github.com/marketplace/models
# CHUMP_PROVIDER_6_ENABLED=1
# CHUMP_PROVIDER_6_NAME=github
# CHUMP_PROVIDER_6_BASE=https://models.inference.ai.azure.com
# CHUMP_PROVIDER_6_KEY=ghp_xxxxxxxxxxxxxxxxxxxx
# CHUMP_PROVIDER_6_MODEL=Meta-Llama-3.3-70B-Instruct
# CHUMP_PROVIDER_6_RPM=12
# CHUMP_PROVIDER_6_RPD=120
# CHUMP_PROVIDER_6_CONTEXT_K=8
# CHUMP_PROVIDER_6_TIER=cloud
# CHUMP_PROVIDER_6_PRIORITY=35
#
# Slot 7: NVIDIA NIM — decent RPM, 5k RPD. Get key: https://build.nvidia.com (needs phone)
# CHUMP_PROVIDER_7_ENABLED=1
# CHUMP_PROVIDER_7_NAME=nvidia
# CHUMP_PROVIDER_7_BASE=https://integrate.api.nvidia.com/v1
# CHUMP_PROVIDER_7_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx
# CHUMP_PROVIDER_7_MODEL=meta/llama-3.3-70b-instruct
# CHUMP_PROVIDER_7_RPM=32
# CHUMP_PROVIDER_7_RPD=5000
# CHUMP_PROVIDER_7_TIER=cloud
# CHUMP_PROVIDER_7_PRIORITY=40
#
# Slot 8: SambaNova — $5 free credit (~months of heartbeat usage). Get key: https://cloud.sambanova.ai
# CHUMP_PROVIDER_8_ENABLED=1
# CHUMP_PROVIDER_8_NAME=sambanova
# CHUMP_PROVIDER_8_BASE=https://api.sambanova.ai/v1
# CHUMP_PROVIDER_8_KEY=xxxxxxxxxxxxxxxxxxxx
# CHUMP_PROVIDER_8_MODEL=Meta-Llama-3.3-70B-Instruct
# CHUMP_PROVIDER_8_RPM=20
# CHUMP_PROVIDER_8_RPD=5000
# CHUMP_PROVIDER_8_TIER=cloud
# CHUMP_PROVIDER_8_PRIORITY=45
#
# Slot 9: xAI (Grok) — grok-3-fast, $25/mo credit, 60 RPH. Get key: https://console.x.ai
# CHUMP_PROVIDER_9_ENABLED=1
# CHUMP_PROVIDER_9_NAME=xai
# CHUMP_PROVIDER_9_BASE=https://api.x.ai/v1
# CHUMP_PROVIDER_9_KEY=xai-xxxxxxxxxxxxxxxxxxxx
# CHUMP_PROVIDER_9_MODEL=grok-3-fast
# CHUMP_PROVIDER_9_RPM=5
# CHUMP_PROVIDER_9_RPD=1400
# CHUMP_PROVIDER_9_TIER=cloud
# CHUMP_PROVIDER_9_PRIORITY=50
#
# Slot 10: Scaleway — 1M free tokens, EU, OpenAI-compatible. Get key: scaleway.com → Generative APIs (SCW_SECRET_KEY)
# CHUMP_PROVIDER_10_ENABLED=1
# CHUMP_PROVIDER_10_NAME=scaleway
# CHUMP_PROVIDER_10_BASE=https://api.scaleway.ai/v1
# CHUMP_PROVIDER_10_KEY=your_scw_secret_key
# CHUMP_PROVIDER_10_MODEL=llama-3.3-70b-instruct
# CHUMP_PROVIDER_10_RPM=30
# CHUMP_PROVIDER_10_RPD=2000
# CHUMP_PROVIDER_10_TIER=cloud
# CHUMP_PROVIDER_10_PRIORITY=55
