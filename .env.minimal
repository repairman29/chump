# Chump — minimal .env for first run
# Copy this file to .env and you're ready to go with Ollama.
# Full reference: .env.example (400+ options — you don't need them yet).

# --- Inference (Ollama) ---
OPENAI_API_BASE=http://localhost:11434/v1
OPENAI_API_KEY=ollama
OPENAI_MODEL=qwen2.5:7b

# --- Dogfood-tuned timeouts and context (24GB Apple Silicon baseline) ---
# Default 30s tool timeout is too short at ~2 tok/s on local LLMs.
CHUMP_TOOL_TIMEOUT_SECS=180
# Override the light-mode 1024-token cap for real coding turns.
CHUMP_COMPLETION_MAX_TOKENS=4096
# Default num_ctx is 8192; raise so long sessions don't truncate.
CHUMP_OLLAMA_NUM_CTX=16384

# --- Paths (auto-detected if omitted, but explicit is safer) ---
# CHUMP_HOME=/path/to/this/repo
# CHUMP_REPO=/path/to/this/repo

# --- Logging (sensible default) ---
RUST_LOG=warn,chump=info

# --- Discord (optional — comment out to skip) ---
# DISCORD_TOKEN=your_bot_token_here
# DISCORD_GUILD_ID=your_guild_id
# DISCORD_CHANNEL_ID=your_channel_id

# --- Tip: set OLLAMA_KEEP_ALIVE=1h before brew/launchd starts Ollama ---
# This keeps the model loaded between turns and avoids 5-15s reload delays:
#   launchctl setenv OLLAMA_KEEP_ALIVE 1h
