<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- INFRA-1006: bot-merge watchdog — kills wedged bot-merge.sh procs -->
<!-- Install: bash scripts/setup/install-bot-merge-watchdog.sh        -->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.chump.bot-merge-watchdog</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>REPO_ROOT/scripts/coord/bot-merge-watchdog.sh</string>
    </array>
    <key>WorkingDirectory</key>
    <string>REPO_ROOT</string>
    <key>StartInterval</key>
    <integer>300</integer>
    <key>StandardOutPath</key>
    <string>REPO_ROOT/.chump-locks/bot-merge-watchdog.log</string>
    <key>StandardErrorPath</key>
    <string>REPO_ROOT/.chump-locks/bot-merge-watchdog.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
    </dict>
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
