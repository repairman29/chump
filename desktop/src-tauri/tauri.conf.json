{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chump",
  "version": "0.1.0",
  "identifier": "dev.chump.desktop",
  "build": {
    "frontendDist": "../../web",
    "beforeBuildCommand": "cargo build --release --manifest-path ../../Cargo.toml --bin chump"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Chump · Cowork",
        "width": 1280,
        "height": 840,
        "minWidth": 1024,
        "minHeight": 640,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
