#!/usr/bin/env bash
# bin/chump — INFRA-469: transparent syspolicyd-wedge heal shim
#
# Place $REPO_ROOT/bin first on PATH so every `chump` invocation routes here
# without any per-script wrapper. On macOS Sequoia the dynamic linker can wedge
# a binary's inode in syspolicyd's pending-decision queue; fresh inodes bypass
# it. This shim detects the wedge (wall-clock timeout) and heals via inode-swap
# before retrying — identical to the INFRA-458 chump_with_doctor pattern, but
# generalised at the shim level so no script needs its own wrapper.
#
# Environment knobs:
#   CHUMP_REAL_BINARY    absolute path to the actual chump binary (skip PATH search)
#   CHUMP_INTERNAL_DOCTOR=0   bypass heal logic entirely (raw pass-through)
#   CHUMP_INTERNAL_TIMEOUT=N  wall-clock timeout in seconds (default 30)
#   CHUMP_DOCTOR_PATH    override path to chump-binary-unwedge.sh
#
# Recursion guard: sets CHUMP_SHIM_ACTIVE=1 before exec-ing the real binary so
# a re-entrant shim invocation (e.g. chump-binary-unwedge.sh probing via `chump`) falls
# through to the real binary immediately.

set -euo pipefail

# ── Recursion guard ───────────────────────────────────────────────────────────
if [[ "${CHUMP_SHIM_ACTIVE:-0}" == "1" ]]; then
    exec "${CHUMP_REAL_BINARY:?CHUMP_SHIM_ACTIVE set but CHUMP_REAL_BINARY empty}" "$@"
fi

# ── Locate real binary ────────────────────────────────────────────────────────
_SHIM_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
_REPO_ROOT="$(dirname "$_SHIM_DIR")"

if [[ -n "${CHUMP_REAL_BINARY:-}" ]]; then
    _REAL="$CHUMP_REAL_BINARY"
else
    # Walk PATH, skip any entry that resolves to this shim's directory.
    _REAL=""
    _old_IFS="$IFS"
    IFS=:
    for _dir in $PATH; do
        IFS="$_old_IFS"
        [[ -z "$_dir" ]] && _dir="."
        # Resolve symlinks so we detect indirect self-references.
        _resolved="$(cd "$_dir" 2>/dev/null && pwd -P || echo "$_dir")"
        [[ "$_resolved" == "$_SHIM_DIR" ]] && continue
        if [[ -x "$_dir/chump" ]]; then
            _REAL="$_dir/chump"
            break
        fi
    done
    IFS="$_old_IFS"

    if [[ -z "$_REAL" ]]; then
        # Fall back to well-known install location.
        if [[ -x "$HOME/.cargo/bin/chump" ]]; then
            _REAL="$HOME/.cargo/bin/chump"
        else
            printf 'chump-shim: cannot locate real chump binary in PATH or ~/.cargo/bin\n' >&2
            exit 1
        fi
    fi
fi

# ── Bypass ────────────────────────────────────────────────────────────────────
if [[ "${CHUMP_INTERNAL_DOCTOR:-1}" == "0" ]]; then
    export CHUMP_SHIM_ACTIVE=1
    export CHUMP_REAL_BINARY="$_REAL"
    exec "$_REAL" "$@"
fi

# ── Timeout helper ────────────────────────────────────────────────────────────
_TIMEOUT="${CHUMP_INTERNAL_TIMEOUT:-30}"
_TO=()
if command -v gtimeout >/dev/null 2>&1; then
    _TO=(gtimeout "$_TIMEOUT")
elif command -v timeout >/dev/null 2>&1; then
    _TO=(timeout "$_TIMEOUT")
fi

# ── First attempt ─────────────────────────────────────────────────────────────
export CHUMP_SHIM_ACTIVE=1
export CHUMP_REAL_BINARY="$_REAL"

# Use || so set -e doesn't exit on non-zero; we need to inspect the code.
"${_TO[@]}" "$_REAL" "$@" && _rc=0 || _rc=$?

# rc 124 = GNU coreutils timeout; rc 137 = SIGKILL (macOS/BSD timeout).
# Either signals a wall-clock stall — the syspolicyd wedge symptom.
if [[ $_rc -ne 124 && $_rc -ne 137 ]]; then
    exit $_rc
fi

# ── Wedge detected — heal via inode-swap, then retry ────────────────────────
printf 'chump-shim: chump timed out (%ss) — syspolicyd inode wedge suspected; healing (INFRA-469)\n' \
    "$_TIMEOUT" >&2

_DOCTOR="${CHUMP_DOCTOR_PATH:-$_REPO_ROOT/scripts/dev/chump-binary-unwedge.sh}"
if [[ -x "$_DOCTOR" ]]; then
    CHUMP_DOCTOR_FORCE=1 CHUMP_DOCTOR_QUIET=1 bash "$_DOCTOR" >/dev/null 2>&1 || true
    # After inode-swap the binary lives at the same path with a new inode.
    # CHUMP_REAL_BINARY still points to the right path; no update needed.
else
    printf 'chump-shim: chump-binary-unwedge.sh not found at %s — retrying without heal\n' "$_DOCTOR" >&2
fi

"${_TO[@]}" "$_REAL" "$@" && _rc=0 || _rc=$?

if [[ $_rc -eq 0 ]]; then
    printf 'chump-shim: recovered after inode heal (INFRA-469)\n' >&2
elif [[ $_rc -eq 124 || $_rc -eq 137 ]]; then
    printf 'chump-shim: still wedged after heal — surfacing failure\n' >&2
fi

exit $_rc
