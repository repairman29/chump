# block; this is the prompt that points at the right test files.
# Bypass: CHUMP_DEFAULT_FLIP_CHECK=0 (silent).

DEFAULT_FLIP_HOOK="$REPO_ROOT/scripts/git-hooks/pre-commit-default-flip.sh"
if [ -x "$DEFAULT_FLIP_HOOK" ]; then
    "$DEFAULT_FLIP_HOOK" || true
fi

