#!/usr/bin/env bash
#
# Chump pre-commit hook: coordination checks.
#
# Each check is independently bypassable via its own env var; `git commit
# --no-verify` bypasses ALL of them. The CLAUDE.md "Pre-commit guards"
# table is the canonical inventory — keep it in sync when adding a check.
#
# 1. Lease-collision guard (agent_lease): refuse to commit a file that is
#    claimed by a DIFFERENT live session in `.chump-locks/`. Prevents silent
#    stomps when two agents race on the same path. Default ON; bypass with
#    `CHUMP_LEASE_CHECK=0` or `git commit --no-verify`. See
#    `docs/AGENT_COORDINATION.md` for the full coordination model.
#
# 2. Stomp-warning (INFRA-WORKTREE-STAGING): non-blocking warning when
#    staged files have a working-tree mtime older than CHUMP_STOMP_WARN_SECS
#    (default 600s). Catches the case where agent A `git add`s a file but
#    doesn't commit, agent B `git add`s something unrelated, and the stale
#    file silently rides along in B's commit. Default ON; disable with
#    `CHUMP_STOMP_WARN=0`.
#
# 3. gaps.yaml write discipline (coordination audit 2026-04-17): rejects
#    commits that add `status: in_progress` / `claimed_by:` / `claimed_at:`
#    lines to docs/gaps.yaml — those fields live in `.chump-locks/` lease
#    files, not the ledger. Also bundles four sub-checks under the same
#    bypass (CHUMP_GAPS_LOCK=0):
#      - duplicate-ID insert (INFRA-GAPS-DEDUP, 2026-04-19): two gaps with
#        the same id in the staged file
#      - gap-ID hijack (2026-04-18): an existing gap's title/description
#        being silently rewritten under the same id
#      - recycled-ID (INFRA-014, 2026-04-21): reopening a closed (status:
#        done) gap with new content
#      - preregistration required (RESEARCH-019): closing an EVAL-* /
#        RESEARCH-* gap to status: done without a preregistered hypothesis
#        doc; bypass via CHUMP_PREREG_CHECK=0
#      - preregistration content check (INFRA-113): when a prereg file
#        exists, validate it locks sample size, judge identity, A/A
#        baseline plan, effect threshold, and prohibited-claims
#        attestation per docs/RESEARCH_INTEGRITY.md; bypass via
#        CHUMP_PREREG_CONTENT_CHECK=0 (justify in PR body)
#      - cross-judge audit (INFRA-079): when an EVAL-* / RESEARCH-*
#        gap closes, the gap entry must reference a cross-judge audit
#        artifact (≥2 judge families) OR carry an explicit
#        single_judge_waived + reason field OR have a preregistration
#        that declares single-judge scope; bypass via
#        CHUMP_CROSS_JUDGE_CHECK=0 (justify in PR body)
#
# 4. Submodule sanity (INFRA-018, 2026-04-19): rejects commits that add a
#    new gitlink (mode 160000) without a matching `.gitmodules` entry. The
#    sql-migrate gitlink incident broke actions/checkout on every PR for
#    days. Bypass: CHUMP_SUBMODULE_CHECK=0.
#
# 5. Cargo-fmt auto-fix: keep the tree cargo-fmt-clean so CI's
#    `cargo fmt --all -- --check` never trips. With multiple agents
#    committing in parallel, drift was happening every few commits and
#    burning 20 minutes per dependabot rebase.
#
# 6. Cargo-check build guard (coordination audit 2026-04-17): refuse
#    to commit code that doesn't compile. Kills the "fix(ci):" follow-up
#    churn — 12 such commits in 48h (8% of all commits) were the cost
#    of letting broken-compile commits land. ~5-15s incremental on the
#    developer's machine; saves ~5 minutes of CI queue time per mistake.
#    Default ON; bypass with `CHUMP_CHECK_BUILD=0` for genuine WIP
#    commits or `git commit --no-verify`. Only runs when staged .rs
#    files are present.
#
# 7. Docs-delta check (INFRA-009, 2026-04-20): warn (or block, per env)
#    when a code change lands without a corresponding docs touch.
#    Bypass: CHUMP_DOCS_DELTA_CHECK=0.
#
# 8. Credential-pattern guard (INFRA-018, 2026-04-20): scan staged content
#    for likely API keys / tokens before they hit git history. Bypass:
#    CHUMP_CREDENTIAL_CHECK=0.
#
# Install once: `./scripts/setup/install-hooks.sh`
# Skip for one commit: `git commit --no-verify` (use sparingly — also
# skips the lease check, which defeats the coordination system).

set -e

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd)

# ------------------------------------------------------------------
# 1. Lease-collision guard
# ------------------------------------------------------------------

if [ "${CHUMP_LEASE_CHECK:-1}" != "0" ]; then
    LOCKS_DIR="$REPO_ROOT/.chump-locks"
    if [ -d "$LOCKS_DIR" ]; then
        # Same session-ID precedence as src/agent_lease.rs::current_session_id:
        # CHUMP_SESSION_ID env → $HOME/.chump/session_id → (unknown; don't block).
        MY_SESSION_ID="${CHUMP_SESSION_ID:-}"
        if [ -z "$MY_SESSION_ID" ] && [ -f "$HOME/.chump/session_id" ]; then
            MY_SESSION_ID=$(head -n1 "$HOME/.chump/session_id" 2>/dev/null | tr -d '[:space:]')
        fi

        STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR || true)

        # Only run if we have both a session ID AND staged files. When a
        # contributor commits without a session ID (pure-human flow) we let
        # them through — lease conflicts only matter between bots with IDs.
        if [ -n "$STAGED_FILES" ] && [ -n "$MY_SESSION_ID" ]; then
            now_epoch=$(date -u +%s)
            conflict=""

            for lease_file in "$LOCKS_DIR"/*.json; do
                [ -f "$lease_file" ] || continue

                holder=$(sed -n 's/.*"session_id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$lease_file" | head -n1)
                [ -n "$holder" ] || continue
                [ "$holder" = "$MY_SESSION_ID" ] && continue

                # Expiry check — RFC3339 -> epoch. macOS uses -j -f, Linux uses -d.
                # Unparseable → treat as live (safer: block rather than stomp).
                expires=$(sed -n 's/.*"expires_at"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$lease_file" | head -n1)
                exp_epoch=""
                if [ -n "$expires" ]; then
                    if [ "$(uname -s)" = "Darwin" ]; then
                        exp_epoch=$(date -u -j -f "%Y-%m-%dT%H:%M:%SZ" "$expires" +%s 2>/dev/null || true)
                    else
                        exp_epoch=$(date -u -d "$expires" +%s 2>/dev/null || true)
                    fi
                fi
                if [ -n "$exp_epoch" ] && [ "$exp_epoch" -le "$now_epoch" ]; then
                    continue  # expired
                fi

                # Extract paths[] from the JSON. Handles BOTH formats we see:
                #   - pretty-printed (one path per line), written by Rust atomic_write
                #   - compact single-line array, written by some external agents
                # Logic: include the line that STARTS the paths array, include
                # subsequent lines until we see `]` (which closes the array).
                # Don't `next` past the starting line or the compact `[...]`
                # form loses everything.
                # Filter out the literal "paths" token which slips through
                # the quoted-string extractor.
                paths=$(awk '
                    /"paths"[[:space:]]*:/ { flag=1 }
                    flag            { print }
                    flag && /\]/    { flag=0 }
                ' "$lease_file" \
                    | grep -oE '"[^"]+"' \
                    | sed 's/^"//;s/"$//' \
                    | grep -vx 'paths' || true)

                for pattern in $paths; do
                    [ -n "$pattern" ] || continue

                    # Determine match mode from the pattern.
                    #   `**`           → matches everything
                    #   `foo/bar/**`   → prefix `foo/bar/`
                    #   `foo/bar/`     → prefix `foo/bar/`
                    #   `foo/bar.rs`   → exact match
                    prefix=""
                    exact=""
                    if [ "$pattern" = "**" ]; then
                        prefix=""
                        exact=""
                        # Matches everything — just mark conflict against the first staged file.
                        first_staged=$(printf '%s\n' "$STAGED_FILES" | head -n1)
                        conflict="$first_staged  (claimed by $holder as wildcard $pattern)"
                        break 2
                    elif [ "${pattern%/\*\*}" != "$pattern" ]; then
                        prefix="${pattern%/\*\*}/"
                    elif [ "${pattern%/}" != "$pattern" ]; then
                        prefix="$pattern"
                    else
                        exact="$pattern"
                    fi

                    while IFS= read -r staged; do
                        [ -n "$staged" ] || continue
                        if [ -n "$prefix" ]; then
                            case "$staged/" in
                                "$prefix"*)
                                    conflict="$staged  (claimed by $holder as prefix $pattern)"
                                    break 2
                                    ;;
                            esac
                        elif [ -n "$exact" ] && [ "$staged" = "$exact" ]; then
                            conflict="$staged  (claimed exactly by $holder)"
                            break 2
                        fi
                    done <<EOF_STAGED
$STAGED_FILES
EOF_STAGED
                done
            done

            if [ -n "$conflict" ]; then
                echo "[pre-commit] LEASE CONFLICT — another agent claims files you're committing:" >&2
                echo "[pre-commit]   $conflict" >&2
                echo "[pre-commit]" >&2
                echo "[pre-commit] Options:" >&2
                echo "[pre-commit]   - wait for the other session's lease to expire (chump --leases)" >&2
                echo "[pre-commit]   - coordinate directly; have them release their lease" >&2
                echo "[pre-commit]   - bypass: CHUMP_LEASE_CHECK=0 git commit ..." >&2
                echo "[pre-commit]   - skip ALL hooks: git commit --no-verify" >&2
                exit 1
            fi
        fi
    fi
fi

# ------------------------------------------------------------------
# 1b. Out-of-scope guard (INFRA-189, 2026-05-01)
# ------------------------------------------------------------------
#
# When MY OWN session's lease declares `paths`, warn (or block) on
# staged files OUTSIDE that declared scope. Section 1 protects OTHER
# agents from my commits; this section protects ME from accidentally
# touching files outside my declared scope (the wrong-worktree-commit
# class observed twice on 2026-04-17, and the cross-fixture-leak class
# that produced INFRA-076's Test <test@test.com> co-author).
#
# Default: WARN mode (non-blocking) when the lease has paths declared.
#   CHUMP_SCOPE_CHECK=0       → disable entirely
#   CHUMP_SCOPE_CHECK=1       → warn (default)
#   CHUMP_SCOPE_CHECK=enforce → block
#
# Starting in warn mode for a week so we observe false-positive rate
# on real commits before flipping the default to enforce.

if [ "${CHUMP_SCOPE_CHECK:-1}" != "0" ]; then
    LOCKS_DIR="$REPO_ROOT/.chump-locks"
    if [ -d "$LOCKS_DIR" ]; then
        MY_SESSION_ID="${CHUMP_SESSION_ID:-}"
        if [ -z "$MY_SESSION_ID" ] && [ -f "$HOME/.chump/session_id" ]; then
            MY_SESSION_ID=$(head -n1 "$HOME/.chump/session_id" 2>/dev/null | tr -d '[:space:]')
        fi
        STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR || true)

        if [ -n "$MY_SESSION_ID" ] && [ -n "$STAGED_FILES" ]; then
            my_lease=""
            for lease_file in "$LOCKS_DIR"/*.json; do
                [ -f "$lease_file" ] || continue
                holder=$(sed -n 's/.*"session_id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$lease_file" | head -n1)
                if [ "$holder" = "$MY_SESSION_ID" ]; then
                    my_lease="$lease_file"
                    break
                fi
            done

            if [ -n "$my_lease" ]; then
                # Same parser as section 1 lease-collision.
                my_paths=$(awk '
                    /"paths"[[:space:]]*:/ { flag=1 }
                    flag            { print }
                    flag && /\]/    { flag=0 }
                ' "$my_lease" \
                    | grep -oE '"[^"]+"' \
                    | sed 's/^"//;s/"$//' \
                    | grep -vx 'paths' || true)

                # No paths declared → no-op (consistent with today's behavior;
                # agents that don't declare scope work as before).
                if [ -n "$my_paths" ]; then
                    # Always-allowed: canonical "every gap touches" paths +
                    # the lease file itself. Normal close/commit flows never
                    # trip this guard.
                    canonical_allowed="docs/gaps.yaml .chump/state.sql .chump/state.db .chump-locks/$(basename "$my_lease")"

                    out_of_scope=""
                    while IFS= read -r staged; do
                        [ -n "$staged" ] || continue
                        case " $canonical_allowed " in
                            *" $staged "*) continue ;;
                        esac
                        # Per-gap row file (post-INFRA-188): docs/gaps/INFRA-NNN.yaml
                        case "$staged" in
                            docs/gaps/*.yaml) continue ;;
                        esac

                        matched=0
                        for pattern in $my_paths; do
                            [ -n "$pattern" ] || continue
                            if [ "$pattern" = "**" ]; then
                                matched=1; break
                            fi
                            if [ "${pattern%/\*\*}" != "$pattern" ]; then
                                prefix="${pattern%/\*\*}/"
                                case "$staged/" in
                                    "$prefix"*) matched=1; break ;;
                                esac
                            elif [ "${pattern%/}" != "$pattern" ]; then
                                case "$staged/" in
                                    "$pattern"*) matched=1; break ;;
                                esac
                            else
                                if [ "$staged" = "$pattern" ]; then
                                    matched=1; break
                                fi
                            fi
                        done

                        if [ "$matched" -eq 0 ]; then
                            out_of_scope="${out_of_scope}${staged}\n"
                        fi
                    done <<EOF_STAGED
$STAGED_FILES
EOF_STAGED

                    if [ -n "$out_of_scope" ]; then
                        if [ "${CHUMP_SCOPE_CHECK:-1}" = "enforce" ]; then
                            echo "[pre-commit] OUT-OF-SCOPE COMMIT BLOCKED (INFRA-189):" >&2
                            echo "[pre-commit]   Your lease declares paths: $my_paths" >&2
                            echo "[pre-commit]   But you're committing files outside that scope:" >&2
                            printf '%b' "$out_of_scope" | sed 's/^/[pre-commit]     /' >&2
                            echo "[pre-commit]" >&2
                            echo "[pre-commit] Options:" >&2
                            echo "[pre-commit]   - update your lease scope: edit $my_lease and add the path to paths[]" >&2
                            echo "[pre-commit]   - commit only in-scope: git restore --staged <file>" >&2
                            echo "[pre-commit]   - bypass: CHUMP_SCOPE_CHECK=0 git commit ..." >&2
                            exit 1
                        else
                            echo "[pre-commit] WARN: out-of-scope commit (INFRA-189 advisory mode):" >&2
                            echo "[pre-commit]   Your lease declares paths: $my_paths" >&2
                            echo "[pre-commit]   But you're committing files outside:" >&2
                            printf '%b' "$out_of_scope" | sed 's/^/[pre-commit]     /' >&2
                            echo "[pre-commit] (warning only — set CHUMP_SCOPE_CHECK=enforce to block)" >&2
                        fi
                    fi
                fi
            fi
        fi
    fi
fi

# ------------------------------------------------------------------
# 2. Stomp-warning — non-blocking flag for stale staged files
# ------------------------------------------------------------------
#
# Background: the main Chump worktree is shared by multiple agents. When
# agent A `git add`s foo.rs at 14:00 and agent B runs `git add bar.rs &&
# git commit` at 14:30, B's commit silently includes A's staged foo.rs.
# Observed twice in one session (cf79287 + a5b5053 in gaps.yaml).
#
# Heuristic: if ANY staged file has a working-tree mtime older than
# CHUMP_STOMP_WARN_SECS seconds, warn on stderr. Non-blocking — this is
# intentionally advisory. False positives (legitimate commits that touch
# files edited hours ago) are noise, not blockers. True positives save
# us from silent stomps.

if [ "${CHUMP_STOMP_WARN:-1}" != "0" ]; then
    STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR || true)
    if [ -n "$STAGED_FILES" ]; then
        now_epoch=$(date -u +%s)
        threshold="${CHUMP_STOMP_WARN_SECS:-600}"
        stale_lines=""
        while IFS= read -r f; do
            [ -z "$f" ] && continue
            # Only check files that still exist in the working tree.
            # Deletions and renames-to-nonexistent are out of scope.
            [ -f "$f" ] || continue
            # stat flags differ macOS vs Linux. Try macOS first; fall back to
            # Linux on failure.
            mtime=$(stat -f %m "$f" 2>/dev/null || stat -c %Y "$f" 2>/dev/null || echo 0)
            [ "$mtime" -gt 0 ] || continue
            age=$((now_epoch - mtime))
            if [ "$age" -gt "$threshold" ]; then
                stale_lines="${stale_lines}  - $f (mtime ${age}s ago)"$'\n'
            fi
        done <<EOF_STAGED
$STAGED_FILES
EOF_STAGED

        if [ -n "$stale_lines" ]; then
            echo "[pre-commit] STOMP WARNING — staged files with mtime > ${threshold}s:" >&2
            printf '%s' "$stale_lines" >&2
            echo "[pre-commit] If these were staged by another agent, unstage them now:" >&2
            echo "[pre-commit]   git reset HEAD <file>" >&2
            echo "[pre-commit] Prefer scripts/coord/chump-commit.sh <file1> [...] -m '...' which" >&2
            echo "[pre-commit] resets unrelated staging automatically." >&2
            # Opt-in hard block: CHUMP_STRICT_STAGING=1 promotes the warning to
            # an error. Off by default because human commits often bundle
            # legit multi-file changes with stale mtimes (e.g. touched a week
            # ago). Bot sessions should set this in their env.
            if [ "${CHUMP_STRICT_STAGING:-0}" = "1" ]; then
                echo "[pre-commit] CHUMP_STRICT_STAGING=1 — refusing commit." >&2
                exit 1
            fi
            echo "[pre-commit] If legitimate, proceed. To silence: CHUMP_STOMP_WARN=0 git commit ..." >&2
            echo "[pre-commit] Threshold tuning: CHUMP_STOMP_WARN_SECS=<seconds>" >&2
        fi
    fi
fi

# ------------------------------------------------------------------
# 3. gaps.yaml write discipline (runs BEFORE fmt early-exit so it
#    catches yaml-only commits too)
# ------------------------------------------------------------------
#
# Per CLAUDE.md: status/claim fields live in .chump-locks/ lease files,
# NOT in docs/gaps.yaml. This hook rejects adds of `status: in_progress`,
# `claimed_by:`, or `claimed_at:` lines on staged gaps.yaml to stop the
# hot-write loop (6 docs(gaps) commits in 48h before this audit).

if [ "${CHUMP_GAPS_LOCK:-1}" != "0" ]; then
    # INFRA-188: trigger on per-file docs/gaps/*.yaml OR legacy monolithic docs/gaps.yaml
    if git diff --cached --name-only --diff-filter=ACM | grep -qE '^docs/gaps(\.yaml|/[^/]+\.yaml)$'; then
        # NEW (INFRA-073, 2026-04-25): YAML-validity guard.
        # Catches commits that leave a gap YAML file unparseable. Concrete
        # incident: commit 26e74937 (INFRA-070) wrote `- regression test:
        # hand-add ...` as an unquoted list item — the embedded colon
        # turned the list item into a malformed mapping. The YAML stayed
        # broken until PR #542 drive-by quoted it. While the file was
        # invalid, `chump-orchestrator` cli_smoke tests crashed with
        # "could not find expected ':'" in CI for every PR.
        # This guard runs PyYAML's safe_load on the staged content;
        # any parse error blocks the commit. Bypass: CHUMP_GAPS_LOCK=0
        if command -v python3 >/dev/null 2>&1; then
            yaml_err=$(python3 - <<'PYEOF_YAMLLINT'
import subprocess, sys, re
try:
    import yaml
except ImportError:
    sys.exit(0)  # PyYAML not installed — silent skip (CI catches it)
def _gaps_text(ref=None):
    """Read all gaps as monolithic YAML text from per-file or monolithic layout."""
    prefix = f"{ref}:" if ref else ":"
    try:
        if ref is None:
            ls_out = subprocess.check_output(["git","ls-files","--cached","docs/gaps/"],
                                             text=True,stderr=subprocess.DEVNULL)
        else:
            ls_out = subprocess.check_output(["git","ls-tree","--name-only","-r",ref,"docs/gaps/"],
                                             text=True,stderr=subprocess.DEVNULL)
        files = sorted(f for f in ls_out.splitlines() if f.endswith(".yaml"))
        if files:
            parts = [subprocess.check_output(["git","show",f"{prefix}{f}"],
                                             text=True,stderr=subprocess.DEVNULL).rstrip()
                     for f in files]
            return "gaps:\n" + "\n".join(parts) + "\n"
    except Exception:
        pass
    try:
        return subprocess.check_output(["git","show",f"{prefix}docs/gaps.yaml"],
                                       text=True,stderr=subprocess.DEVNULL)
    except Exception:
        return ""
# Check each staged gap file for valid YAML
errors = []
staged_files = subprocess.check_output(
    ["git","diff","--cached","--name-only","--diff-filter=ACM"],
    text=True, stderr=subprocess.DEVNULL).splitlines()
for f in staged_files:
    if not (f == "docs/gaps.yaml" or (f.startswith("docs/gaps/") and f.endswith(".yaml"))):
        continue
    try:
        content = subprocess.check_output(["git","show",f":{f}"],
                                          text=True,stderr=subprocess.DEVNULL)
        yaml.safe_load(content)
    except yaml.YAMLError as e:
        errors.append(f"{f}: {e}")
    except Exception:
        pass
print("\n".join(errors))
PYEOF_YAMLLINT
)
            if [ -n "$yaml_err" ]; then
                echo "[pre-commit] gap YAML INVALID — staged gap file does not parse:" >&2
                printf '%s\n' "$yaml_err" | sed 's/^/  /' >&2
                echo "" >&2
                echo "[pre-commit] Fix the offending line (often: an unquoted colon in a list" >&2
                echo "[pre-commit]   item value, e.g. '- regression test: foo' should be" >&2
                echo "[pre-commit]   '- ''regression test: foo''' or use a block scalar (>)." >&2
                echo "[pre-commit] Bypass: CHUMP_GAPS_LOCK=0 git commit ..." >&2
                exit 1
            fi
        fi

        # Added lines only (ignore context + deletions).
        # INFRA-188: check per-file docs/gaps/*.yaml AND legacy docs/gaps.yaml
        added=$(git diff --cached --unified=0 -- 'docs/gaps.yaml' 'docs/gaps/*.yaml' \
            | grep -E '^\+[^+]' | sed 's/^\+//')
        offending=""
        if printf '%s\n' "$added" | grep -qE '^[[:space:]]*status:[[:space:]]*in_progress[[:space:]]*$'; then
            offending="${offending}  - adds 'status: in_progress' (put claim in .chump-locks/ instead)"$'\n'
        fi
        if printf '%s\n' "$added" | grep -qE '^[[:space:]]*claimed_by:[[:space:]]*'; then
            offending="${offending}  - adds 'claimed_by:' (put claim in .chump-locks/ instead)"$'\n'
        fi
        if printf '%s\n' "$added" | grep -qE '^[[:space:]]*claimed_at:[[:space:]]*'; then
            offending="${offending}  - adds 'claimed_at:' (put claim in .chump-locks/ instead)"$'\n'
        fi
        if [ -n "$offending" ]; then
            echo "[pre-commit] gap-row DISCIPLINE — per CLAUDE.md, claim state lives in .chump-locks/" >&2
            printf '%s' "$offending" >&2
            echo "[pre-commit] Claim the gap via: scripts/coord/gap-claim.sh <GAP-ID>" >&2
            echo "[pre-commit] Only flip docs/gaps/<ID>.yaml on ship (status: done + closed_pr + closed_date)." >&2
            echo "[pre-commit] Bypass: CHUMP_GAPS_LOCK=0 git commit ..." >&2
            exit 1
        fi

        # NEW (INFRA-GAPS-DEDUP 2026-04-19): duplicate-ID guard.
        # Reject any commit that introduces a NEW gap entry whose id: value
        # already exists in gaps.yaml (either in HEAD or in the staged version).
        # This is the root cause of the 7 collision pairs fixed in INFRA-GAPS-DEDUP.
        # A new id is detected by scanning the added (+) lines for `- id: XXX`
        # and cross-checking against the full staged file (or HEAD).
        # Bypass: CHUMP_GAPS_LOCK=0
        if command -v python3 >/dev/null 2>&1; then
            dup_ids=$(python3 - <<'PYEOF_DUP'
import subprocess, sys, re
def _gaps_text(ref=None):
    prefix = f"{ref}:" if ref else ":"
    try:
        cmd = ["git","ls-files","--cached","docs/gaps/"] if ref is None else \
              ["git","ls-tree","--name-only","-r",ref,"docs/gaps/"]
        ls_out = subprocess.check_output(cmd,text=True,stderr=subprocess.DEVNULL)
        files = sorted(f for f in ls_out.splitlines() if f.endswith(".yaml"))
        if files:
            parts = [subprocess.check_output(["git","show",f"{prefix}{f}"],
                                             text=True,stderr=subprocess.DEVNULL).rstrip()
                     for f in files]
            return "gaps:\n" + "\n".join(parts) + "\n"
    except Exception:
        pass
    try:
        return subprocess.check_output(["git","show",f"{prefix}docs/gaps.yaml"],
                                       text=True,stderr=subprocess.DEVNULL)
    except Exception:
        return ""
# Get the staged gaps content (per-file or monolithic)
staged = _gaps_text()
if not staged:
    sys.exit(0)
# Collect all ids in the staged content
all_ids = re.findall(r'^\s*-\s*id:\s*(\S+)', staged, re.MULTILINE)
# Find duplicates
seen = {}
dups = []
for gid in all_ids:
    if gid in seen:
        if gid not in dups:
            dups.append(gid)
    else:
        seen[gid] = 1
if dups:
    print("\n".join(dups))
PYEOF_DUP
)
