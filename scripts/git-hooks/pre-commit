# Refuses commits whose staged diff adds substantial feature code
# (default >50 lines across .rs/.sh/.py) but introduces ZERO new
# observability hooks (tracing macros, ambient events, lessons writes).
# Same "observability before scale" doctrine as INFRA-754, applied at
# the commit-stats level instead of the event-shape level.
# Bypass: CHUMP_OBS_BUDGET_BYPASS=1 (add `Obs-Bypass-Reason: <reason>`
# trailer to commit body).

OBS_BUDGET_HOOK="$REPO_ROOT/scripts/git-hooks/pre-commit-obs-budget.sh"
if [ -x "$OBS_BUDGET_HOOK" ]; then
    if ! "$OBS_BUDGET_HOOK"; then
        exit 1
    fi
fi

