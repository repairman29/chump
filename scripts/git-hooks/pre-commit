    if [ "$ADDED" -gt 0 ] && [ "$ADDED" -gt "$DELETED" ]; then
        MSG_FILE="${1:-$REPO_ROOT/.git/COMMIT_EDITMSG}"
        NET=$((ADDED - DELETED))
        # INFRA-124 (2026-05-02): parse the trailer's value, not just its
        # presence. Previously a commit could declare "Net-new-docs: +1"
        # while actually adding 5 docs and the guard would accept it. The
        # trailer must now equal or exceed the computed NET delta.
        TRAILER_VAL=""
        if [ -f "$MSG_FILE" ]; then
