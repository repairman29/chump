            fi
        elif [ "$TRAILER_VAL" -lt "$NET" ]; then
            # INFRA-124: trailer present but understates the delta — reject.
            echo ""
            echo "✖  docs-delta (INFRA-124): trailer claims Net-new-docs: +$TRAILER_VAL"
            echo "   but commit actually adds $ADDED docs/*.md, deletes $DELETED (net +$NET)."
