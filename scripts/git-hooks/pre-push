#!/usr/bin/env bash
#
# Chump pre-push hook: gap-preflight guard + auto-merge armed guard.
#
# Guard 1 (gap-preflight): Automatically extracts gap IDs from commits being
# pushed and runs gap-preflight.sh against them. Aborts if any gap is already
# `done` on origin/main or claimed by another session — preventing wasted CI
# runs and duplicate work landing.
# Bypass: CHUMP_GAP_CHECK=0 git push  (use when gap IDs in commit bodies cause false positives)
#
# Guard 2 (auto-merge armed): Queries `gh pr view` for the target branch and
# aborts if the PR already has auto-merge armed. This prevents the PR #52
# footgun where 11 commits were lost because an agent kept pushing after
# auto-merge was armed and GitHub captured the branch at first-CI-green.
# Bypass: CHUMP_AUTOMERGE_OVERRIDE=1 git push  (emergency use only)
#
# Auto-skip (INFRA-368): When `git reflog` shows a "rebase" entry within the
# last REBASE_DETECT_WINDOW_S seconds (default 300), Guards 1+2 silently
# auto-skip. The canonical DIRTY-after-arm recovery is "rebase + force-push" —
# the auto-merge-armed guard would otherwise treat it as the PR #52 footgun.
# Guard 3 still runs (race protection applies regardless). Disable detection
# with CHUMP_REBASE_DETECT=0.
#
# Guard 3 (force-with-lease race protection — INFRA-345): On a force-push,
# verifies the actual current remote tip matches what the local fetched view
# expected. `git push --force-with-lease` only protects against the ref-tip
# you've fetched moving — it does NOT protect against a sibling pushing
# between your fetch and your push (the lease-check uses your stale local
# refs/remotes/<remote>/<branch>). PR #910 incident, 2026-05-03: clobbered a
# sibling's commit b484c152 that landed in the ~2-minute window between my
# fetch and my push. This guard does a fresh `git ls-remote` immediately
# before allowing a force-push and aborts if the remote tip has moved.
# Bypass: CHUMP_FORCE_LEASE_CHECK=0 git push  (use when intentional)
#
# Guard 4 (bot-merge required for new gap branches — INFRA-719): On a
# first-push (new branch) of a chump/<gap-id>-* branch, requires that the
# push was initiated by bot-merge.sh (CHUMP_BOT_MERGE_IN_PROGRESS=1).
# Prevents the "git push -u origin branch + gh pr create" manual bypass which
# skips gap-ship-fatal (INFRA-678) and the auto-close hook (INFRA-154).
# Bypass: CHUMP_BYPASS_BOT_MERGE=1 git push  (rare; add a comment why)
#
# Install once: ./scripts/setup/install-hooks.sh

set -euo pipefail

# Never block pushes to main/master — those go through PR only.
REMOTE="$1"
# $2 is the remote URL; unused here.

# -----------------------------------------------------------------------
# INFRA-1028: operator-recovery umbrella
# CHUMP_OPERATOR_RECOVERY=1 enables the bypass set for human-supervised
# manual recovery. Emits guard_bypassed to ambient.jsonl for audit trail.
# -----------------------------------------------------------------------
if [ "${CHUMP_OPERATOR_RECOVERY:-0}" = "1" ]; then
    export CHUMP_BYPASS_BOT_MERGE=1
    export CHUMP_GAP_CHECK=0
    export CHUMP_ALLOW_UNREGISTERED_GAP=1
    export CHUMP_ALLOW_REUSE_BRANCH=1
    export CHUMP_ALLOW_GAP_REWRITE=1
    export CHUMP_TEST_GATE=0
    _or_ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    _or_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
    mkdir -p "${_or_root}/.chump-locks" 2>/dev/null || true
    printf '{"ts":"%s","kind":"guard_bypassed","guard_name":"operator_recovery_umbrella","bypasses":["CHUMP_BYPASS_BOT_MERGE","CHUMP_GAP_CHECK","CHUMP_TEST_GATE","CHUMP_ALLOW_UNREGISTERED_GAP"],"operator":true}\n' \
        "$_or_ts" >> "${_or_root}/.chump-locks/ambient.jsonl" 2>/dev/null || true
    unset _or_ts _or_root
fi

# -----------------------------------------------------------------------
# Guard 0: cargo fmt --check (INFRA-749)
#
# Fleet workers can bypass the pre-commit hook (--no-verify) or skip
# bot-merge.sh entirely, pushing unformatted code that blocks CI. This
# guard catches the gap: it runs at push time, is independent of how
# commits were created, and is fast (~1-2s on cached builds).
# Bypass: CHUMP_FMT_CHECK=0 git push
# -----------------------------------------------------------------------
if [[ "${CHUMP_FMT_CHECK:-1}" != "0" ]] && command -v cargo &>/dev/null; then
    # INFRA-1398: gate on the PUSH DELTA's .rs content, not on whether the repo
    # has any Rust files at all. Pre-1398 the `ls src/**/*.rs` glob was always
    # true (chump is a Rust repo), so doc-only / ci.yml-only pushes ran
    # cargo fmt --check unnecessarily — slow + irrelevant.
    #
    # Push range: stdin gives `<local-sha> <local-ref> <remote-sha> <remote-ref>`.
    # When we cannot derive a range (first-push of a new branch, no stdin
    # available because hook called manually), fall back to the OLD behaviour
    # (run on every push) — safer default.
    push_has_rust=0
    while IFS=' ' read -r local_sha local_ref remote_sha _remote_ref; do
        [[ -z "$local_sha" ]] && continue
        # Skip branch deletions (local_sha all zeros).
        if [[ "$local_sha" =~ ^0+$ ]]; then continue; fi
        # First push of branch: remote_sha is zeros → compare against origin/main.
        if [[ "$remote_sha" =~ ^0+$ ]]; then
            range_base="$(git merge-base origin/main "$local_sha" 2>/dev/null || echo "")"
            [[ -z "$range_base" ]] && range_base="origin/main"
        else
            range_base="$remote_sha"
        fi
        if git diff --name-only "$range_base..$local_sha" 2>/dev/null | grep -qE '\.rs$'; then
            push_has_rust=1
            break
        fi
    done <<<"$(cat 2>/dev/null || true)"
    # Conservative fallback: if we couldn't read stdin (manual invocation) AND
    # the repo has Rust files, run the check to avoid silently letting bad
    # code through.
    if [[ "$push_has_rust" -eq 0 ]] && [[ -t 0 ]] && ls src/**/*.rs &>/dev/null 2>&1; then
        push_has_rust=1
    fi
    if [[ "$push_has_rust" -eq 1 ]]; then
        if ! cargo fmt --all -- --check >/dev/null 2>&1; then
            echo "" >&2
            echo "[pre-push] BLOCKED: cargo fmt --check failed (INFRA-749)." >&2
            echo "[pre-push] Unformatted Rust code cannot be pushed — CI will reject it." >&2
            echo "" >&2
            echo "[pre-push] Fix: cargo fmt --all && git add -u && git commit --amend --no-edit" >&2
            echo "[pre-push] Bypass: CHUMP_FMT_CHECK=0 git push" >&2
            echo "" >&2
            exit 1
        fi
    fi
fi

# -----------------------------------------------------------------------
# Guard 0d: drop ghost test-fixture commits (INFRA-1408)
#
# Some CI test scripts (notably scripts/ci/test-api-broadcast.sh and
# scripts/ci/test-claim-*.sh) run `git init && git add -A && git commit -m s`
# inside scratch dirs to fabricate fixture repos. When those scratch dirs
# overlap with the repo (or when a sibling-bot pushes into a feature branch),
# the resulting "init" commits authored by `Test <test@test.local>` leak into
# real PR branches and get caught by pr-hygiene (CREDIBLE-027) at CI time —
# wasting one full CI cycle per occurrence.
#
# This guard scans the commits being pushed (zero-arg local-ref form of pre-
# push input). For any commit authored by a name matching the fixture regex
# (default '^Test.*@test\.local$'), it prints a warning and refuses the push.
# Operator can interactively drop them via `git rebase --interactive base~N`
# or pass --auto-drop to have the hook do it.
#
# Bypass: CHUMP_FIXTURE_AUTHOR_GUARD=0 git push
# Auto-drop: CHUMP_AUTODROP_FIXTURE_COMMITS=1 git push  (rewrites HEAD)
# Tune regex: CHUMP_FIXTURE_AUTHOR_REGEX='^Test.*@test\.local$|^Fixture<.*>$'
# -----------------------------------------------------------------------
if [[ "${CHUMP_FIXTURE_AUTHOR_GUARD:-1}" != "0" ]]; then
    # Match by domain — the actual ghost commits observed today had
    # author email "test@test.local" (lowercase) so we key on the .local
    # TLD specifically since real authors use .com/.dev/.org/etc.
    _fa_regex="${CHUMP_FIXTURE_AUTHOR_REGEX:-@(test|fixture|example)\.local$}"
    # Read stdin only when we have one; pre-push hooks get refs on stdin.
    # The git revisions to scan are determined by the diff between the
    # being-pushed ref and its remote tracking ref. If there is no remote
    # tracking ref (new branch), scan everything not yet on origin/main.
    _fa_local_sha="$(git rev-parse HEAD 2>/dev/null || echo HEAD)"
    _fa_base="$(git merge-base "$_fa_local_sha" origin/main 2>/dev/null || echo "")"
    if [[ -n "$_fa_base" && "$_fa_base" != "$_fa_local_sha" ]]; then
        _fa_ghosts="$(git log --format='%H %ae' "${_fa_base}..${_fa_local_sha}" 2>/dev/null | \
            grep -E " ${_fa_regex}" | awk '{print $1}' || true)"
        if [[ -n "$_fa_ghosts" ]]; then
            echo "" >&2
            echo "[pre-push] BLOCKED: $(echo "$_fa_ghosts" | wc -l | tr -d ' ') ghost commit(s) authored by Test<test@test.local> or similar detected (INFRA-1408)." >&2
            echo "[pre-push] These leak from CI test fixtures running 'git init' in shared dirs and trigger pr-hygiene/CREDIBLE-027 at CI time." >&2
            echo "" >&2
            echo "$_fa_ghosts" | while read -r _sha; do
                git log -1 --format='  %h %ae — %s' "$_sha" >&2
            done
            echo "" >&2
            if [[ "${CHUMP_AUTODROP_FIXTURE_COMMITS:-0}" = "1" ]]; then
                echo "[pre-push] CHUMP_AUTODROP_FIXTURE_COMMITS=1 — attempting auto-drop via rebase --onto" >&2
                # Build a rebase --onto base ghost~ HEAD for each (in order)
                # Simplest reliable approach: cherry-pick all non-ghost commits onto base
                _fa_keep="$(git log --format='%H %ae' "${_fa_base}..${_fa_local_sha}" --reverse | \
                    grep -vE " ${_fa_regex}" | awk '{print $1}')"
                _fa_branch="$(git rev-parse --abbrev-ref HEAD)"
                git checkout -q "$_fa_base"
                _fa_failed=0
                for _sha in $_fa_keep; do
                    if ! git cherry-pick "$_sha" >/dev/null 2>&1; then
                        _fa_failed=1
                        git cherry-pick --abort >/dev/null 2>&1 || true
                        break
                    fi
                done
                if [[ $_fa_failed -eq 1 ]]; then
                    git checkout -q "$_fa_branch"
                    echo "[pre-push] auto-drop failed; manual fix required: git rebase -i $_fa_base" >&2
                    exit 1
                fi
                git branch -f "$_fa_branch" HEAD
                git checkout -q "$_fa_branch"
                # Emit ambient event
                _fa_repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"
                _fa_ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
                printf '{"ts":"%s","kind":"fixture_commit_dropped","branch":"%s","dropped_count":%d}\n' \
                    "$_fa_ts" "$_fa_branch" "$(echo "$_fa_ghosts" | wc -l | tr -d ' ')" \
                    >> "${_fa_repo_root}/.chump-locks/ambient.jsonl" 2>/dev/null || true
                unset _fa_ts _fa_repo_root
                echo "[pre-push] auto-drop succeeded — ghost commits removed from $_fa_branch" >&2
            else
                echo "[pre-push] Drop manually: git rebase -i $_fa_base    (delete the ghost lines)" >&2
                echo "[pre-push] Or: CHUMP_AUTODROP_FIXTURE_COMMITS=1 git push   (rewrites local branch)" >&2
                echo "[pre-push] Bypass:    CHUMP_FIXTURE_AUTHOR_GUARD=0 git push" >&2
                echo "" >&2
                exit 1
            fi
        fi
    fi
    unset _fa_regex _fa_local_sha _fa_base _fa_ghosts _fa_keep _fa_branch _fa_failed _sha
fi

# -----------------------------------------------------------------------
# Guard 0c: cargo clippy lint gate (INFRA-1390)
#
# Runs cargo clippy on changed crates before the full test suite so
# lint-class CI failures are caught locally in ~10s rather than after a
# 20-min CI cycle.  Only fires when .rs files are changed in the diff.
#
# Disk-pressure guard: clippy on a large codebase needs ~200MB workspace.
# If < CHUMP_CLIPPY_MIN_DISK_KB (default 5000000 = 5 GB) is available,
# the gate fails with an operational message pointing at the reaper script
# (cargo-target-reaper.sh) before wasting time on a doomed cargo invocation.
#
# Bypass (rare):
#   CHUMP_CLIPPY_GATE=0 git push
#   Emits kind=lint_bypass to ambient.jsonl; requires 'Lint-Gate-Bypass: <reason>'
#   trailer in HEAD commit body.  Use when the clippy error is a known
#   upstream regression or when running in lint-deluge state
#   (ambient kind=lint_deluge present in last 10m):
#     CHUMP_LINT_GATE=off git push   (bypass-of-bypass, deluge mode only)
# -----------------------------------------------------------------------
if [[ "${CHUMP_LINT_GATE:-on}" == "off" ]]; then
    echo "[pre-push] CHUMP_LINT_GATE=off — skipping clippy lint gate (lint-deluge mode)" >&2
elif [[ "${CHUMP_CLIPPY_GATE:-1}" == "0" ]]; then
    # Emit lint_bypass telemetry.
    _lg_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
    _lg_branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo unknown)"
    _lg_gap="$(echo "$_lg_branch" | grep -oiE '[A-Za-z]+-[0-9]+' | head -1 | tr '[:lower:]' '[:upper:]' || echo "")"
    _lg_reason="$(git log -1 --pretty=format:%B 2>/dev/null \
        | grep -i '^Lint-Gate-Bypass:' | head -1 \
        | sed 's/^[Ll]int-[Gg]ate-[Bb]ypass:[[:space:]]*//' || echo "")"
    printf '{"ts":"%s","kind":"lint_bypass","gap_id":"%s","reason":"%s","branch":"%s","bypassed_by":"CHUMP_CLIPPY_GATE=0"}\n' \
        "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$_lg_gap" "$_lg_reason" "$_lg_branch" \
        >> "${_lg_root}/.chump-locks/ambient.jsonl" 2>/dev/null || true
    unset _lg_root _lg_branch _lg_gap _lg_reason
elif command -v cargo &>/dev/null; then
    # Determine if any .rs files changed in the push vs origin/main.
    _CLIPPY_HAS_RS=0
    if git fetch origin main --quiet 2>/dev/null; then
        if git diff --name-only origin/main...HEAD 2>/dev/null | grep -qE '\.rs$'; then
            _CLIPPY_HAS_RS=1
        fi
    else
        # Offline — check working tree diff.
        if git diff --name-only HEAD 2>/dev/null | grep -qE '\.rs$'; then
            _CLIPPY_HAS_RS=1
        fi
    fi

    if [[ "$_CLIPPY_HAS_RS" == "1" ]]; then
        # Disk-pressure check before invoking cargo.
        _CLIPPY_MIN_KB="${CHUMP_CLIPPY_MIN_DISK_KB:-5000000}"
        _AVAIL_KB=0
        if command -v df &>/dev/null; then
            # macOS: df -k . → 512-byte blocks; use df -k for kB
            _AVAIL_KB=$(df -k . 2>/dev/null | awk 'NR==2{print $4}' || echo 0)
        fi
        if [[ "$_AVAIL_KB" -lt "$_CLIPPY_MIN_KB" ]] 2>/dev/null; then
            echo "" >&2
            echo "[pre-push] BLOCKED: disk pressure — only ${_AVAIL_KB}KB available, need ${_CLIPPY_MIN_KB}KB for clippy." >&2
            echo "[pre-push] Run the cargo-target reaper to free space:" >&2
            echo "[pre-push]   bash scripts/dev/cargo-target-reaper.sh" >&2
            echo "[pre-push] Or bypass after freeing space: CHUMP_CLIPPY_GATE=0 git push" >&2
            echo "" >&2
            exit 1
        fi

        REPO_ROOT_CL="$(git rev-parse --show-toplevel)"
        echo "[pre-push] INFRA-1390: running cargo clippy (diff has .rs changes)..." >&2
        echo "[pre-push] Bypass: CHUMP_CLIPPY_GATE=0 git push  (with Lint-Gate-Bypass: trailer)" >&2

        _WT_CLIPPY_TARGET="$REPO_ROOT_CL/.cargo-test-target"

        # Run clippy; capture exit code.
        if ! (cd "$REPO_ROOT_CL" && CARGO_TARGET_DIR="$_WT_CLIPPY_TARGET" \
            cargo clippy --all-targets --quiet -- -D warnings) 2>&1; then
            echo "" >&2
            echo "[pre-push] BLOCKED: cargo clippy -D warnings failed (INFRA-1390)." >&2
            echo "[pre-push] Lint errors must be fixed before pushing — CI will reject them." >&2
            echo "[pre-push] Fix: cargo clippy --all-targets -- -D warnings  # then git add -u && git commit --amend" >&2
            echo "" >&2
            echo "[pre-push] Bypass (rare — lint infra broken, known upstream regression):" >&2
            echo "[pre-push]   CHUMP_CLIPPY_GATE=0 git push" >&2
            echo "[pre-push]   Add 'Lint-Gate-Bypass: <reason>' to HEAD commit body." >&2
            echo "" >&2
            exit 1
        fi
        echo "[pre-push] INFRA-1390: ✓ clippy clean" >&2
    fi
fi

# -----------------------------------------------------------------------
# Guard 0b: cargo-test full-suite gate (INFRA-761)
#
# Pre-push runs `cargo test --bin chump --tests --no-fail-fast --quiet`
# when the push contains any .rs file change. Catches the "I ran scoped
# tests locally and it passed" failure mode (e.g. EVAL-026 #1349 author
# updated env_flags.rs test but missed neuromodulation.rs:340 — full
# suite would have caught it before push).
#
# Cost mitigation:
#   1. SKIP when no .rs files changed in the push range (docs-only / sh-only)
#   2. CACHE result keyed on tree-hash; re-push of same tree → skip
#   3. AUTO-SKIP on rebase (INFRA-368 detection — same code, just moved)
#
# Bypass: CHUMP_TEST_GATE=0 git push
#   When bypassing for a real reason (test infra broken, local-only spike),
#   include `Test-Gate-Bypass: <reason>` in the HEAD commit body so the
#   operator audit log can grep the trailer.
#
# Performance budget: 4–6 min on a clean target/. Cached re-runs are <1s.
# -----------------------------------------------------------------------

# RESILIENT-014: emit ambient audit event when the test gate is bypassed.
if [[ "${CHUMP_TEST_GATE:-1}" == "0" ]]; then
    _r014_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
    _r014_branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo unknown)"
    _r014_gap="$(echo "$_r014_branch" | grep -oiE '[A-Za-z]+-[0-9]+' | head -1 | tr '[:lower:]' '[:upper:]' || echo "")"
    _r014_reason="$(git log -1 --pretty=format:%B 2>/dev/null \
        | grep -i '^Test-Gate-Bypass:' | head -1 \
        | sed 's/^[Tt]est-[Gg]ate-[Bb]ypass:[[:space:]]*//' || echo "")"
    _r014_ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    mkdir -p "${_r014_root}/.chump-locks" 2>/dev/null || true
    printf '{"ts":"%s","kind":"test_gate_bypassed","gap_id":"%s","reason":"%s","branch":"%s","bypassed_by":"CHUMP_TEST_GATE=0"}\n' \
        "$_r014_ts" "$_r014_gap" "$_r014_reason" "$_r014_branch" \
        >> "${_r014_root}/.chump-locks/ambient.jsonl" 2>/dev/null || true
    unset _r014_root _r014_branch _r014_gap _r014_reason _r014_ts
fi

if [[ "${CHUMP_TEST_GATE:-1}" != "0" ]] && command -v cargo &>/dev/null; then
    REPO_ROOT_T="$(git rev-parse --show-toplevel)"
    CACHE_DIR="$REPO_ROOT_T/.chump-locks/test-gate-cache"
    TREE_SHA="$(git rev-parse HEAD^{tree} 2>/dev/null || echo unknown)"
    CACHE_MARKER="$CACHE_DIR/${TREE_SHA}.ok"

    # Fast cache hit: this exact tree was tested green before.
    if [[ -f "$CACHE_MARKER" ]]; then
        # Silent on cache hit — keeps the happy-path quiet.
        :
    elif detect_recent_rebase 2>/dev/null; then
        # Rebase auto-skip: same code, was tested when first pushed.
        :
    else
        # Determine whether any .rs file changed in the push range. We read
        # stdin (the standard pre-push protocol: lines of
        # "<local_ref> <local_sha> <remote_ref> <remote_sha>"). If stdin is
        # already consumed by a later guard, fall back to the diff against
        # origin/main for a robust default.
        ANY_RS=0
        if [[ -t 0 ]] || [[ -z "${CHUMP_TEST_GATE_RANGE:-}" ]]; then
            # Stdin is a terminal or unset — use origin/main fallback.
            if git fetch origin main --quiet 2>/dev/null; then
                if git diff --name-only origin/main...HEAD 2>/dev/null \
                    | grep -qE '\.rs$'; then
                    ANY_RS=1
                fi
            else
                # Offline or no main — assume Rust changed (be conservative).
                ANY_RS=1
            fi
        fi

        if [[ "$ANY_RS" == "1" ]]; then
            echo "[pre-push] INFRA-761: running cargo test --bin chump --tests (full suite)..." >&2
            echo "[pre-push] (one-time per tree-hash; cached at $CACHE_MARKER on green)" >&2
            echo "[pre-push] Bypass: CHUMP_TEST_GATE=0 git push  (with Test-Gate-Bypass: trailer)" >&2

            # Unset bot-dispatch git identity so test-spawned git ops
            # don't inherit chump-dispatch@chump.bot (INFRA-813).
            unset GIT_AUTHOR_EMAIL GIT_COMMITTER_EMAIL GIT_AUTHOR_NAME GIT_COMMITTER_NAME

            # INFRA-1167: build --skip list from KNOWN_FLAKES.yaml so environment-
            # dependent parallel-test races never block a legitimate push. Skipped
            # tests are announced upfront; CHUMP_TEST_GATE=0 remains emergency bypass.
            _SKIP_ARGS=()
            _CATALOG="$REPO_ROOT_T/docs/process/KNOWN_FLAKES.yaml"
            if [[ -f "$_CATALOG" ]]; then
                while IFS= read -r _tname; do
                    [[ -z "$_tname" ]] && continue
                    # Warn if entry lacks a tracking_gap (discipline check, AC 6).
                    if ! grep -A5 "test: ${_tname}" "$_CATALOG" 2>/dev/null \
                            | grep -q "tracking_gap:"; then
                        echo "[pre-push] WARN: KNOWN_FLAKES entry '${_tname}' has no tracking_gap — add one (INFRA-764)" >&2
                    fi
                    echo "[pre-push] SKIP (known flake): ${_tname}" >&2
                    if [[ "${#_SKIP_ARGS[@]}" -eq 0 ]]; then
                        _SKIP_ARGS+=("--")
                    fi
                    _SKIP_ARGS+=("--skip" "${_tname}")
                done < <(grep -E '^[[:space:]]*-[[:space:]]*test:' "$_CATALOG" \
                    | sed -E 's/^[[:space:]]*-[[:space:]]*test:[[:space:]]+//; s/"//g; s/[[:space:]]*$//')
            fi

            # RESILIENT-012: capture test output to temp file so we can parse
            # failing test names against KNOWN_FLAKES.yaml for auto-bypass.
            _TEST_LOG="$(mktemp -t pre-push-test.XXXXXX)"
            # shellcheck disable=SC2064
            trap "rm -f '$_TEST_LOG'" EXIT

            # --no-fail-fast so we surface the full failure list, not just first.
            # --quiet trims the per-test PASS lines but keeps FAILED lines.
            # RESILIENT-009: cd to REPO_ROOT_T so cargo test runs in the linked
            # worktree, not the invoking shell's cwd (main checkout). Without this,
            # GIT_DIR overrides cause tests to run against main's source tree even
            # when pushing from a linked worktree.
            # INFRA-1138: use per-worktree target directory for the test run to
            # prevent phantom fingerprint contamination from sibling worktrees that
            # share the same CARGO_TARGET_DIR (set by install-sccache.sh / INFRA-481).
            # The shared sccache (via rustc-wrapper in .cargo/config.toml) still
            # provides cross-worktree object-code caching; only fingerprints are
            # isolated. Per-worktree path ensures each linked worktree's test run
            # sees only its own source file set.
            _WT_TEST_TARGET="$REPO_ROOT_T/.cargo-test-target"
            # INFRA-1316: bash 3.2 + `set -u` aborts on `"${arr[@]}"` when
            # the array is empty. KNOWN_FLAKES.yaml has zero entries today,
            # so the subshell crashed before cargo test ever ran and the
            # hook falsely reported "tests failed" on every push.
            #
            # `${arr[@]:+"${arr[@]}"}` is the canonical safe idiom: it
            # expands to the array contents iff set-and-non-empty, otherwise
            # to nothing (zero args, not one empty arg — important because
            # cargo test treats `""` as a filter and silently runs zero tests).
            # INFRA-1403: prefer cargo-test-with-rerun.sh when available; it handles
            # KNOWN_FLAKES auto-rerun and structured ambient telemetry internally,
            # superseding the RESILIENT-012 manual bypass logic in the fallback path.
            _RERUN_SCRIPT="$REPO_ROOT_T/scripts/ci/cargo-test-with-rerun.sh"
            if [[ -x "$_RERUN_SCRIPT" ]]; then
                if (cd "$REPO_ROOT_T" && CARGO_TARGET_DIR="$_WT_TEST_TARGET" \
                    bash "$_RERUN_SCRIPT" -- \
                        cargo test --bin chump --tests --no-fail-fast --quiet \
                        ${_SKIP_ARGS[@]:+"${_SKIP_ARGS[@]}"}); then
                    mkdir -p "$CACHE_DIR"
                    date -u +%Y-%m-%dT%H:%M:%SZ > "$CACHE_MARKER"
                    echo "[pre-push] INFRA-761: ✓ full suite green; cached for tree $TREE_SHA" >&2
                else
                    echo "" >&2
                    echo "[pre-push] BLOCKED: test suite failed after flake auto-rerun (INFRA-761/1403)." >&2
                    echo "[pre-push] Classify new flakes in docs/process/KNOWN_FLAKES.yaml (see INFRA-764)." >&2
                    echo "[pre-push] Bypass (rare): CHUMP_TEST_GATE=0 git push" >&2
                    echo "[pre-push]   When bypassing, include 'Test-Gate-Bypass: <reason>' in" >&2
                    echo "[pre-push]   the HEAD commit body so the audit log can find the trailer." >&2
                    echo "" >&2
                    exit 1
                fi
            else
                # Fallback (RESILIENT-012): direct cargo test with post-failure parse
                # against KNOWN_FLAKES.yaml for auto-bypass when wrapper is absent.
                if (cd "$REPO_ROOT_T" && CARGO_TARGET_DIR="$_WT_TEST_TARGET" \
                    cargo test --bin chump --tests --no-fail-fast --quiet \
                        ${_SKIP_ARGS[@]:+"${_SKIP_ARGS[@]}"}) 2>&1 \
                    | tee "$_TEST_LOG" | tail -200; then
                    mkdir -p "$CACHE_DIR"
                    date -u +%Y-%m-%dT%H:%M:%SZ > "$CACHE_MARKER"
                    echo "[pre-push] INFRA-761: ✓ full suite green; cached for tree $TREE_SHA" >&2
                else
                    # RESILIENT-012: auto-bypass if ALL failing tests are in KNOWN_FLAKES.yaml.
                    # Prevents manual Test-Gate-Bypass trailers for pre-existing main failures.
                    _CATALOG="$REPO_ROOT_T/docs/process/KNOWN_FLAKES.yaml"
                    # `|| true` defuses `set -e + pipefail`: when grep finds
                    # zero "test FOO ... FAILED" lines (compile error, panic,
                    # mock-cargo failure, etc.), the pipeline exits 1 and
                    # aborts the hook BEFORE the BLOCKED diagnostic can fire.
                    _FAILED=$(grep -E '^test [A-Za-z_][A-Za-z0-9_:]+ \.\.\. FAILED' "$_TEST_LOG" \
                        | sed -E 's/^test ([A-Za-z_][A-Za-z0-9_:]+) .*/\1/' \
                        | sort -u || true)
                    _ALL_KNOWN=1
                    _UNKNOWN_TESTS=()
                    if [[ -n "$_FAILED" && -f "$_CATALOG" ]]; then
                        _CATALOG_TESTS=$(grep -E '^[[:space:]]*-[[:space:]]*test:' "$_CATALOG" \
                            | sed -E 's/^[[:space:]]*-[[:space:]]*test:[[:space:]]+//; s/"//g; s/[[:space:]]*$//')
                        while IFS= read -r _tname; do
                            [[ -z "$_tname" ]] && continue
                            if ! printf '%s\n' "$_CATALOG_TESTS" | grep -qxF "$_tname"; then
                                _ALL_KNOWN=0
                                _UNKNOWN_TESTS+=("$_tname")
                            fi
                        done <<< "$_FAILED"
                    else
                        # No parseable failures (compile error?) or no catalog — treat as real failure.
                        _ALL_KNOWN=0
                    fi

                    if [[ "$_ALL_KNOWN" -eq 1 && -n "$_FAILED" ]]; then
                        _FAILED_LIST=$(printf '%s\n' "$_FAILED" | tr '\n' ' ')
                        echo "" >&2
                        echo "[pre-push] RESILIENT-012: all failures are catalogued in KNOWN_FLAKES.yaml — auto-bypassing gate" >&2
                        echo "[pre-push] Known flakes: $_FAILED_LIST" >&2
                        echo "[pre-push] (no Test-Gate-Bypass trailer needed; these are pre-existing main failures)" >&2
                        mkdir -p "$CACHE_DIR"
                        date -u +%Y-%m-%dT%H:%M:%SZ > "$CACHE_MARKER"
                    else
                        echo "" >&2
                        echo "[pre-push] BLOCKED: cargo test --bin chump --tests failed (INFRA-761)." >&2
                        echo "[pre-push] Full-suite test failure cannot be pushed — CI would reject." >&2
                        if [[ "${#_UNKNOWN_TESTS[@]}" -gt 0 ]]; then
                            echo "[pre-push] Unknown failures (not in KNOWN_FLAKES.yaml):" >&2
                            for _t in "${_UNKNOWN_TESTS[@]}"; do
                                echo "[pre-push]   $_t" >&2
                            done
                        fi
                        echo "" >&2
                        echo "[pre-push] If this is a known pre-existing flake, classify it via" >&2
                        echo "[pre-push]   docs/process/KNOWN_FLAKES.yaml (see INFRA-764) and rerun." >&2
                        echo "[pre-push] Bypass (rare): CHUMP_TEST_GATE=0 git push" >&2
                        echo "[pre-push]   When bypassing, include 'Test-Gate-Bypass: <reason>' in" >&2
                        echo "[pre-push]   the HEAD commit body so the audit log can find the trailer." >&2
                        echo "" >&2
                        exit 1
                    fi
                fi
            fi  # end if [[ -x "$_RERUN_SCRIPT" ]]
        else
            # INFRA-1403: no .rs changes in this push — skip test gate and emit telemetry.
            _AMBIENT_LOG="$REPO_ROOT_T/.chump-locks/ambient.jsonl"
            _BRANCH="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo unknown)"
            mkdir -p "$(dirname "$_AMBIENT_LOG")" 2>/dev/null || true
            printf '{"ts":"%s","event":"INFO","kind":"pre_push_test_gate_skipped","reason":"no_rust_changes","branch":"%s","source":"pre-push"}\n' \
                "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$_BRANCH" \
                >> "$_AMBIENT_LOG" 2>/dev/null || true
            echo "[pre-push] INFRA-1403: no .rs changes — test gate skipped." >&2
        fi  # end if [[ "$ANY_RS" == "1" ]]
    fi
fi

# INFRA-368: detect a legitimate rebase force-push so Guards 1+2 silently
# auto-skip (Guard 3 still runs — race protection applies regardless).
#
# Heuristic: git's reflog records "rebase (start)/(finish)" for both
# `git rebase` and `git pull --rebase`. If we see one within the last
# REBASE_DETECT_WINDOW_S seconds, treat the push as a rebase finalization.
# Bypass: CHUMP_REBASE_DETECT=0 to disable detection (force the guards on).
#
# Why skip Guard 2 (auto-merge armed) on rebase: the canonical recovery
# pattern for a DIRTY-after-arm PR is exactly "rebase + force-push" — the
# guard treats every push-after-arm as the PR #52 footgun, which it isn't
# when the diff is unchanged and only the parent commit moved.
# Why skip Guard 1 (gap-preflight) on rebase: same gap IDs in commits;
# preflight already ran when the original push went out.
# Why KEEP Guard 3 (force-with-lease race): a sibling can still push
# between your fetch+rebase and your force-push — that's what Guard 3
# catches, regardless of whether your push is a rebase or a rewrite.
detect_recent_rebase() {
    [[ "${CHUMP_REBASE_DETECT:-1}" == "0" ]] && return 1
    local window_s="${REBASE_DETECT_WINDOW_S:-300}"  # 5 min default
    # `git reflog show HEAD --since=...` doesn't filter by message; manually
    # check the last 50 entries for a "rebase" message within the window.
    # Format: "<sha> HEAD@{<idx>}: <message>" — use --date=unix on @{...}
    # via a separate parse since reflog --date= prints the AUTHOR date,
    # not the reflog-entry date. Use git reflog --date=iso-local instead.
    local now last_ts
    now=$(date +%s)
    while IFS=$'\t' read -r ts_str msg; do
        [[ "$msg" == *"rebase"* ]] || continue
        # ts_str format: "Mon May  3 12:34:56 2026"; convert via date -j -f
        last_ts=$(date -j -f '%a %b %e %H:%M:%S %Y' "$ts_str" '+%s' 2>/dev/null \
                  || date -d "$ts_str" '+%s' 2>/dev/null)
        [[ -z "$last_ts" ]] && continue
        if (( now - last_ts < window_s )); then
            return 0  # found a recent rebase
        fi
    done < <(git reflog show HEAD --date=local --format='%cd	%gs' -50 2>/dev/null)
    return 1
}

# Read the list of refs being pushed from stdin (format: local_ref local_sha remote_ref remote_sha)
while read -r local_ref local_sha remote_ref remote_sha; do
    branch="${remote_ref#refs/heads/}"

    # Skip if pushing to main/master (branch protection handles that).
    [[ "$branch" == "main" || "$branch" == "master" ]] && continue

    # -----------------------------------------------------------------------
    # Guard 4: bot-merge required for new gap branch pushes (INFRA-719)
    #
    # A first-push (remote_sha == 0x40 zeros) of a chump/<gap-id>-* branch
    # must go through bot-merge.sh so gap-ship-fatal (INFRA-678) and the
    # INFRA-154 auto-close hook always fire. Manual "git push + gh pr create"
    # bypasses both and leaves gaps in status:open after their PR merges.
    # -----------------------------------------------------------------------
    ZERO_SHA="0000000000000000000000000000000000000000"
    if [[ "$remote_sha" == "$ZERO_SHA" ]] \
        && [[ "$branch" =~ ^chump/[a-zA-Z]+-[0-9]+ ]] \
        && [[ "${CHUMP_BOT_MERGE_IN_PROGRESS:-0}" != "1" ]] \
        && [[ "${CHUMP_BYPASS_BOT_MERGE:-0}" != "1" ]]; then
        echo "[pre-push] Bypass: CHUMP_BYPASS_BOT_MERGE=1 git push  (or CHUMP_OPERATOR_RECOVERY=1 for full recovery mode)" >&2
        echo "[pre-push] BLOCKED (INFRA-719): direct push of gap branch '$branch' to a new PR." >&2
        echo "[pre-push] Use bot-merge.sh to ship gap branches — it wires gap-ship-fatal" >&2
        echo "[pre-push] (INFRA-678) and the auto-close hook (INFRA-154)." >&2
        echo "" >&2
        echo "[pre-push] Ship command:" >&2
        echo "[pre-push]   scripts/coord/bot-merge.sh --gap <GAP-ID> --auto-merge" >&2
        echo "" >&2
        exit 1
    fi

    # INFRA-368: capture rebase state once per pushed ref so the per-guard
    # checks don't all re-grep the reflog.
    REBASE_DETECTED=0
    if detect_recent_rebase; then
        REBASE_DETECTED=1
        echo "[pre-push] INFRA-368: recent rebase detected (within ${REBASE_DETECT_WINDOW_S:-300}s) — auto-skip Guards 1+2 for $branch" >&2
    fi

    # -----------------------------------------------------------------------
    # Guard 2: Auto-merge armed check (INFRA-PUSH-LOCK)
    # Check before gap-preflight so a fast fail doesn't require running the
    # slower preflight script when auto-merge is the real problem.
    # INFRA-368: skip when REBASE_DETECTED — rebase + force-push is the
    # canonical DIRTY-after-arm recovery, not the PR #52 footgun.
    # -----------------------------------------------------------------------
    if [[ "$REBASE_DETECTED" == "1" ]]; then
        : # auto-skip; Guard 3 still runs
    elif [[ "${CHUMP_AUTOMERGE_OVERRIDE:-0}" == "1" ]]; then
        echo "[pre-push] CHUMP_AUTOMERGE_OVERRIDE=1 — skipping auto-merge armed check for $branch" >&2
    elif command -v gh &>/dev/null; then
        # INFRA-485: also query mergeStateStatus. The PR #52 squash-loss
        # footgun requires the PR to actually be MERGEABLE at first
        # CI-green — mergeStateStatus=CLEAN. Any other state
        # (BLOCKED on failing CI, DIRTY on conflicts, UNSTABLE on
        # non-required checks, BEHIND on out-of-date branch) means
        # GitHub can't merge yet, so pushing more commits is safe and
        # is in fact the intended recovery path. Pre-INFRA-485 the
        # guard fired on ANY auto-merge-armed PR regardless of merge
        # state, blocking legitimate fixes to BLOCKED PRs (observed
        # twice 2026-05-05: INFRA-477 clippy fix push, INFRA-456 test
        # fix push). Operators worked around with CHUMP_AUTOMERGE_OVERRIDE=1
        # which silenced the guard entirely — net safety regression.
        pr_status=$(gh pr view "$branch" --json state,autoMergeRequest,mergeStateStatus \
            --jq 'if .state == "OPEN" and .autoMergeRequest != null then .mergeStateStatus else "no_armed" end' 2>/dev/null || echo "no_pr")

        if [[ "$pr_status" == "CLEAN" ]]; then
            echo "" >&2
            echo "[pre-push] BLOCKED: PR for branch '$branch' has auto-merge armed AND is CLEAN (ready to merge)." >&2
            echo "[pre-push] Pushing now risks the PR #52 squash-loss footgun: GitHub captures the" >&2
            echo "[pre-push] branch at first-CI-green and drops anything pushed afterward (2026-04-18, lost 11 commits)." >&2
            echo "" >&2
            echo "[pre-push] Options:" >&2
            echo "[pre-push]   • Open a NEW PR from a fresh worktree for additional work." >&2
            echo "[pre-push]   • Emergency bypass: CHUMP_AUTOMERGE_OVERRIDE=1 git push" >&2
            echo "" >&2
            exit 1
        elif [[ "$pr_status" =~ ^(BLOCKED|DIRTY|UNSTABLE|BEHIND|UNKNOWN|HAS_HOOKS)$ ]]; then
            # Auto-merge armed but PR can't merge yet — push is safe and
            # is the canonical recovery path (fix CI, rebase, etc.).
            echo "[pre-push] INFRA-485: PR auto-merge armed but mergeStateStatus=$pr_status — push allowed (recovery path)." >&2
        fi
        # "no_armed" → no auto-merge armed → allow
        # "no_pr" → gh errored (no PR) → allow
    else
        # gh not installed or not authenticated — warn but do not block.
        echo "[pre-push] WARNING: 'gh' not found or not authenticated; skipping auto-merge armed check." >&2
    fi

    # -----------------------------------------------------------------------
    # Guard 3: --force-with-lease race protection (INFRA-345)
    #
    # Detect a force-push by checking whether the remote_sha (what we think
    # is at the remote) is an ancestor of local_sha (what we're pushing).
    # For a fast-forward push, remote_sha IS an ancestor → ok.
    # For a force-push, remote_sha is NOT an ancestor → verify freshness.
    # New-branch push (remote_sha = all zeros) is not a force → skip.
    # -----------------------------------------------------------------------
    ZERO_SHA="0000000000000000000000000000000000000000"
    if [[ "${CHUMP_FORCE_LEASE_CHECK:-1}" != "0" ]] \
        && [[ "$remote_sha" != "$ZERO_SHA" ]] \
        && ! git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null
    then
        # This IS a force-push (history rewrite). Compare what the remote
        # ACTUALLY has right now to what our local view said.
        actual_remote_sha=$(git ls-remote "$REMOTE" "$remote_ref" 2>/dev/null | awk '{print $1}')
        if [[ -n "$actual_remote_sha" && "$actual_remote_sha" != "$remote_sha" ]]; then
            echo "" >&2
            echo "[pre-push] BLOCKED: force-push race detected on $branch (INFRA-345)." >&2
            echo "[pre-push]   Local view says remote tip is: $remote_sha" >&2
            echo "[pre-push]   Actual remote tip right now:   $actual_remote_sha" >&2
            echo "[pre-push] A sibling pushed between your last fetch and this push." >&2
            echo "[pre-push] Force-pushing now would clobber their work — \`--force-with-lease\`" >&2
            echo "[pre-push] only protects against the local view moving, not stale fetches." >&2
            echo "[pre-push] (PR #910 incident, 2026-05-03: clobbered b484c152 this way.)" >&2
            echo "" >&2
            echo "[pre-push] Recover by:" >&2
            echo "[pre-push]   git fetch $REMOTE $branch" >&2
            echo "[pre-push]   git log $branch..$REMOTE/$branch  # see what they pushed" >&2
            echo "[pre-push]   git rebase $REMOTE/$branch        # or cherry-pick their commit(s) onto your local" >&2
            echo "[pre-push]   git push --force-with-lease       # retry — guard re-checks freshness" >&2
            echo "" >&2
            echo "[pre-push] Bypass (intentional clobber, e.g. operator-authored cleanup):" >&2
            echo "[pre-push]   CHUMP_FORCE_LEASE_CHECK=0 git push" >&2
            echo "" >&2
            exit 1
        fi
    fi

    # -----------------------------------------------------------------------
    # Guard 1: Gap-preflight check
    # INFRA-368: skip when REBASE_DETECTED — the gap IDs in the rebased
    # commits are unchanged from the original push; preflight already ran.
    # -----------------------------------------------------------------------

    # Skip if bypassed (or rebase auto-skip).
    [[ "$REBASE_DETECTED" == "1" ]] && continue
    [[ "${CHUMP_GAP_CHECK:-1}" == "0" ]] && continue

    # Determine the range of new commits being pushed.
    # If remote sha is all zeros, it's a new branch — compare against origin/main.
    if [[ "$remote_sha" == "0000000000000000000000000000000000000000" ]]; then
        base=$(git merge-base HEAD "origin/main" 2>/dev/null || echo "")
        [[ -z "$base" ]] && continue
        range="${base}..${local_sha}"
    else
        range="${remote_sha}..${local_sha}"
    fi

    # Extract gap IDs from commit subjects only (%s), not bodies.
    # Using %s %b caused false positives when commit bodies mentioned gap IDs
    # in passing (e.g. cleanup commits referencing a gap they didn't implement).
    GAP_IDS=$(git log "$range" --format="%s" 2>/dev/null \
        | grep -oE '\b[A-Z]+-[0-9]+\b' | sort -u || true)

    [[ -z "$GAP_IDS" ]] && continue

    REPO_ROOT="$(git rev-parse --show-toplevel)"
    PREFLIGHT="$REPO_ROOT/scripts/coord/gap-preflight.sh"

    [[ ! -x "$PREFLIGHT" ]] && continue

    echo "[pre-push] Checking gap status for: $(echo $GAP_IDS | tr '\n' ' ')" >&2

    # INFRA-1165: resolve our own session ID from the lease file so gap-preflight
    # can correctly identify that this push belongs to the gap's claimant.
    # Without this, gap-preflight falls back to the machine-global session ID
    # which doesn't match the claim-infra-NNN-PID-TS lease, producing a false
    # "already claimed by another session" rejection.
    _LOCK_DIR="$(git rev-parse --git-common-dir 2>/dev/null || echo ".git")"
    if [[ "$_LOCK_DIR" == ".git" ]]; then
        _LOCK_DIR="$REPO_ROOT/.chump-locks"
    else
        _LOCK_DIR="$(cd "$_LOCK_DIR/.." 2>/dev/null && pwd || echo "$REPO_ROOT")/.chump-locks"
    fi
    _OWN_SESSION=""
    if [[ -d "$_LOCK_DIR" ]]; then
        _OWN_SESSION="$(python3 - "$_LOCK_DIR" $GAP_IDS <<'PYEOF' 2>/dev/null
import json, os, sys
from datetime import datetime, timezone
lock_dir = sys.argv[1]
gap_ids = set(sys.argv[2:])
now = datetime.now(timezone.utc)
for fname in os.listdir(lock_dir):
    if not fname.endswith(".json"):
        continue
    try:
        d = json.load(open(os.path.join(lock_dir, fname)))
    except Exception:
        continue
    if d.get("gap_id") not in gap_ids:
        continue
    try:
        exp = datetime.fromisoformat(d.get("expires_at", "").rstrip("Z")).replace(tzinfo=timezone.utc)
        if (exp - now).total_seconds() <= 0:
            continue  # expired
    except Exception:
        continue
    sid = d.get("session_id", "")
    if sid:
        print(sid)
        break
PYEOF
)"
    fi

    # shellcheck disable=SC2086
    if ! CHUMP_SESSION_ID="${_OWN_SESSION:-}" "$PREFLIGHT" $GAP_IDS; then
        # If we detected a session that matches this push, surface that as a
        # false positive and emit an ambient event for observability (INFRA-1165).
        if [[ -n "$_OWN_SESSION" ]]; then
            echo "[pre-push] WARN: gap-preflight rejected push despite matching lease '$_OWN_SESSION'." >&2
            echo "[pre-push]   This may be a gap-preflight bug — consider filing a follow-up gap." >&2
            _AMBIENT_EMIT="$REPO_ROOT/scripts/dev/ambient-emit.sh"
            if [[ -x "$_AMBIENT_EMIT" ]]; then
                "$_AMBIENT_EMIT" gap_check_false_positive \
                    "gap_ids=$(echo "$GAP_IDS" | tr '\n' ',')" \
                    "session=$_OWN_SESSION" 2>/dev/null || true
            fi
        fi
        echo "[pre-push] Push blocked: one or more gaps already done or claimed." >&2
        echo "[pre-push] This branch's work may already be on main." >&2
        echo "[pre-push] Run: git show origin/main:docs/gaps.yaml | grep -A8 'id: GAP-XYZ'" >&2
        echo "[pre-push] Bypass (when commit bodies cause false positives): CHUMP_GAP_CHECK=0 git push" >&2
        exit 1
    fi
done

exit 0
