<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>ai.chump.sentinel</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-lc</string>
    <string>/path/to/Chump/scripts/sentinel.sh</string>
  </array>
  <key>WorkingDirectory</key>
  <string>/path/to/Chump</string>
  <key>RunAtLoad</key>
  <true/>
  <key>StartInterval</key>
  <integer>300</integer>
  <!-- 300 = 5 min. Checks farmer-brown.log and heartbeat logs; writes sentinel-alert.txt and optionally notifies. -->
  <key>StandardOutPath</key>
  <string>/path/to/Chump/logs/sentinel-launchd.out.log</string>
  <key>StandardErrorPath</key>
  <string>/path/to/Chump/logs/sentinel-launchd.err.log</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/local/bin:/opt/homebrew/bin</string>
  </dict>
</dict>
</plist>
