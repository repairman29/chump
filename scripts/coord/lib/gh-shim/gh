#!/usr/bin/env bash
# scripts/coord/lib/gh-shim/gh — INFRA-999 transparent telemetry shim
#
# Activated by sourcing scripts/coord/lib/github.sh — that file prepends
# this directory to PATH so every subsequent `gh ...` invocation goes
# through this script. Records the call (kind=github_api_call ambient
# event) and forwards to the real gh binary.
#
# Resolves the real gh by searching PATH minus our own directory. This
# avoids the infinite-recursion trap where the shim calls itself.
#
# Bypass: `command gh ...` (bash's `command` strips PATH-resolved scripts
# and runs the binary; only works if no other gh shim is on PATH).
# Or: `CHUMP_GH_NO_SHIM=1 gh ...`.

set -uo pipefail

if [[ "${CHUMP_GH_NO_SHIM:-0}" == "1" ]]; then
    # Recursion guard: caller wants the raw binary. Resolve and exec.
    SHIM_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
    OLD_PATH="$PATH"
    PATH="$(printf '%s' "$OLD_PATH" | tr ':' '\n' | grep -vFx "$SHIM_DIR" | tr '\n' ':' | sed 's/:$//')"
    exec gh "$@"
fi

SHIM_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
REPO_LIB="$(cd "$SHIM_DIR/.." && pwd)"

# Source the github.sh library for the record + tag helpers. Make sure
# this doesn't re-prepend our shim dir (the source guard inside that file
# already handles idempotency, but we set NO_PATH_INJECT just in case).
CHUMP_GH_NO_PATH_INJECT=1 source "$REPO_LIB/github.sh"

# Find the real gh: walk PATH, skip our shim dir.
_real_gh=""
IFS=':' read -r -a _path_parts <<< "$PATH"
for _p in "${_path_parts[@]}"; do
    [[ -z "$_p" ]] && continue
    [[ "$_p" == "$SHIM_DIR" ]] && continue
    if [[ -x "$_p/gh" ]]; then
        _real_gh="$_p/gh"
        break
    fi
done

if [[ -z "$_real_gh" ]]; then
    echo "[chump-gh-shim] real gh not found on PATH (excluding $SHIM_DIR)" >&2
    exit 127
fi

# Tag this call.
api_tag="$(chump_gh_api_tag "$@" 2>/dev/null || echo "?")"

# CREDIBLE-065: walk the ps tree past shells (bash/sh/zsh/dash/fish) AND gh
# itself until we find the real calling script. The previous 2-level walk
# fell back to 'gh' when the shim was called from inside a gh subshell:
#   pr-watch.sh → bash → gh → bash-subshell → gh(shim) → recorded 'gh'
# Now we walk up to 10 levels, skipping any shell or gh ancestor.
_resolve_script_tag() {
    local pid="${1:-$PPID}"
    local name ppid_up depth=0
    while [[ $depth -lt 10 ]]; do
        name="$(ps -o comm= -p "$pid" 2>/dev/null | tr -d ' \t' | head -1 || true)"
        name="$(basename "${name:-}")"
        # Accept first ancestor that is not a shell or gh
        if [[ -n "$name" ]] && \
           [[ "$name" != "bash" && "$name" != "-bash" && \
              "$name" != "sh"   && "$name" != "-sh"   && \
              "$name" != "zsh"  && "$name" != "-zsh"  && \
              "$name" != "dash" && "$name" != "fish"  && \
              "$name" != "gh" ]]; then
            echo "$name"
            return 0
        fi
        ppid_up="$(ps -o ppid= -p "$pid" 2>/dev/null | tr -d ' \t')"
        if [[ -z "$ppid_up" || "$ppid_up" == "0" || "$ppid_up" == "$pid" ]]; then
            break
        fi
        pid="$ppid_up"
        depth=$((depth + 1))
    done
    echo "shim"
}

# Caller-script identity — resolve early so both throttle and record share it.
# Prefer CHUMP_GH_SCRIPT (env override), else walk the process tree.
script_tag="${CHUMP_GH_SCRIPT:-}"
if [[ -z "$script_tag" ]]; then
    script_tag="$(_resolve_script_tag "$PPID")"
fi

# INFRA-1103: invoke throttle for every bare 'gh ...' call that reaches the shim.
#
# Skip when CHUMP_GH_SHIM_RECORDING=1 — this flag is set by either:
#   (a) chump_gh() in github.sh, which already called _chump_gh_throttle_wait
#       before invoking 'gh'; or
#   (b) an outer shim invocation (this shim is nested inside a real gh execution).
# In both cases the throttle was already applied; a second call would double-wait.
#
# CHUMP_GH_NO_THROTTLE=1 is an unconditional bypass (emergency / testing).
if [[ "${CHUMP_GH_SHIM_RECORDING:-0}" != "1" ]]; then
    if declare -F _chump_gh_throttle_wait >/dev/null 2>&1; then
        _chump_gh_throttle_wait "$script_tag" 2>/dev/null || true
    fi
fi

started_ms="$(_chump_gh_now_ms 2>/dev/null || echo 0)"

# INFRA-1103: route every bare `gh` invocation through the same throttle
# that chump_gh() uses. Closes the bypass identified during the 2026-05-13
# secondary-rate-limit incident: INFRA-1079 added _chump_gh_throttle_wait,
# but only the chump_gh function called it — bare `gh ...` via the shim
# was recorded for telemetry but never throttled.
#
# Skip when CHUMP_GH_SHIM_RECORDING is already set: that means chump_gh()
# higher up the stack already throttled, and this exec is the downstream
# `gh "$@"` it issued. Double-waiting would inflate latency and corrupt
# the sliding window. (The same env var is used to skip double-record.)
if [[ "${CHUMP_GH_SHIM_RECORDING:-}" != "1" ]]; then
    # CREDIBLE-065: reuse the already-resolved script_tag (walked via _resolve_script_tag
    # above) rather than duplicating the old 2-level walk here.
    _shim_script_tag="${CHUMP_GH_SCRIPT:-$script_tag}"
    if declare -F _chump_gh_throttle_wait >/dev/null 2>&1; then
        _chump_gh_throttle_wait "$_shim_script_tag" 2>/dev/null || true
    fi
    if declare -F _chump_gh_preempt_if_low >/dev/null 2>&1; then
        _chump_gh_preempt_if_low "$_shim_script_tag" "$api_tag" 2>/dev/null || true
    fi
    unset _shim_script_tag
fi

# INFRA-1282: gh pr view → REST + cache rewrite.
#
# 'gh pr view' is GraphQL. The chump fleet polls hot PRs heavily via
# pr-watch.sh, bot-merge.sh existing-PR check, queue-driver branch lookup
# (74 calls/hr in 2026-05-14 throttle audit). Rewriting at the shim
# layer migrates all 6+ callers to REST + cache with ONE change.
#
# Pattern: gh pr view <PR-or-branch> [--json FIELDS] [-q/--jq EXPR]
# Falls through to real gh on: --watch, --comments, --web, unsupported
# --json fields, branch-name target not in cache, no --json (human table).
#
# Bypass: CHUMP_GH_SHIM_NO_REWRITE=1 forces real gh pr view.
if [[ "${CHUMP_GH_SHIM_NO_REWRITE:-0}" != "1" ]] \
        && [[ "${1:-}" == "pr" ]] && [[ "${2:-}" == "view" ]]; then
    _translator="$SHIM_DIR/pr-view-translate.py"
    if [[ -x "$_translator" ]] && command -v python3.12 >/dev/null 2>&1; then
        # Shift past "pr" "view"; pass remaining args.
        python3.12 "$_translator" "${@:3}"
        _rc=$?
        if [[ "$_rc" == "0" ]]; then
            # Translation succeeded — record as a synthetic call and exit.
            ended_ms="$(_chump_gh_now_ms 2>/dev/null || echo 0)"
            if declare -F chump_gh_record >/dev/null 2>&1; then
                chump_gh_record "pr view [translated]" "$(( ended_ms - started_ms ))" 0 "$script_tag" \
                    2>/dev/null || true
            fi
            exit 0
        fi
        # rc=2 → fall through; rc=3 → PR not found, also fall through so
        # real gh produces the canonical error message.
    fi
fi

# Run real gh, preserve stdout/stderr/exit.
# Mark that the shim is the recording path on this call — any
# explicit chump_gh_record() call from a wrapper higher up the stack
# (e.g. bot-merge.sh::gh_with_backoff) should skip its own emission
# to avoid double-logging.
export CHUMP_GH_SHIM_RECORDING=1
"$_real_gh" "$@"
rc=$?
unset CHUMP_GH_SHIM_RECORDING

ended_ms="$(_chump_gh_now_ms 2>/dev/null || echo 0)"

# Best-effort record. Never blocks/fails the real call.
if declare -F chump_gh_record >/dev/null 2>&1; then
    chump_gh_record "$api_tag" "$(( ended_ms - started_ms ))" "$rc" "$script_tag" \
        2>/dev/null || true
fi

exit $rc
