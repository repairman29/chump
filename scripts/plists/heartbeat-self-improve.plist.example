<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>ai.chump.heartbeat-self-improve</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-lc</string>
    <string>/path/to/Chump/scripts/dev/heartbeat-self-improve.sh</string>
  </array>
  <!-- Replace /path/to/Chump with your repo path (e.g. /Users/you/Projects/Chump). -->
  <key>WorkingDirectory</key>
  <string>/path/to/Chump</string>
  <!-- Run once at load (e.g. on login), then every 8 hours. Each run is one 8h self-improve session. -->
  <key>RunAtLoad</key>
  <true/>
  <key>StartInterval</key>
  <integer>28800</integer>
  <!-- 28800 = 8 hours. For daily: 86400. For 4h: 14400. -->
  <key>StandardOutPath</key>
  <string>/path/to/Chump/logs/heartbeat-self-improve-launchd.out.log</string>
  <key>StandardErrorPath</key>
  <string>/path/to/Chump/logs/heartbeat-self-improve-launchd.err.log</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/local/bin:/opt/homebrew/bin:/Users/you/.local/bin</string>
    <!-- Optional: Cursor runs can take 5–10 min; raise timeout so research_cursor rounds don't kill agent. Script sources .env; set CHUMP_CLI_TIMEOUT_SECS=600 there instead if you prefer. -->
    <!-- <key>CHUMP_CLI_TIMEOUT_SECS</key>
    <string>600</string> -->
  </dict>
</dict>
</plist>
